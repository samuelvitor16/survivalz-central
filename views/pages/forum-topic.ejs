<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/forum.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="forum-section">
      <div class="container">

        <div class="forum-topic-page-header topic-header-v2">
          <div>
            <a href="/forum/categoria/<%= topic.category.slug %>" class="forum-back-link">
              Voltar para <%= topic.category.name %>
            </a>

            <div class="forum-topic-heading-row">
              <span class="section-tag"><%= topic.category.icon || "SZ" %> <%= topic.category.name %></span>
              <span class="forum-topic-status status-<%= topic.status.toLowerCase() %>">
                <%= topicStatusLabel(topic.status) %>
              </span>
            </div>

            <h1><%= topic.title %></h1>

            <p>
              Criado por <a href="/perfil/<%= topic.author.id %>"><strong><%= displayUserName(topic.author) %></strong></a>
              | <%= formatDateTime(topic.createdAt) %>
              | <%= topic.views + 1 %> visualizacoes
            </p>
          </div>

          <% if (canManageTopic || canEditOwnTopic || canDeleteOwnTopic) { %>
            <div class="forum-topic-action-menu" data-action-menu>
              <button type="button" class="forum-topic-action-trigger" data-action-trigger aria-label="Abrir acoes do topico">
                ...
              </button>

              <div class="forum-topic-action-panel" data-action-panel>
                <% if (canManageTopic) { %>
                  <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                    <input type="hidden" name="status" value="OPEN">
                    <button type="submit">Abrir topico</button>
                  </form>
                  <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                    <input type="hidden" name="status" value="CLOSED">
                    <button type="submit">Fechar topico</button>
                  </form>
                  <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                    <input type="hidden" name="status" value="PINNED">
                    <button type="submit">Fixar topico</button>
                  </form>
                  <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                    <input type="hidden" name="status" value="ARCHIVED">
                    <button type="submit">Arquivar topico</button>
                  </form>

                  <form action="/forum/topico/<%= topic.id %>/mover" method="POST" class="forum-topic-move-form">
                    <label for="categoryId">Mover categoria</label>
                    <select id="categoryId" name="categoryId">
                      <% categories.forEach((category) => { %>
                        <option value="<%= category.id %>" <%= category.id === topic.categoryId ? "selected" : "" %>>
                          <%= category.name %>
                        </option>
                      <% }) %>
                    </select>
                    <button type="submit">Mover</button>
                  </form>
                <% } %>

                <% if (canEditOwnTopic) { %>
                  <a href="/forum/topico/<%= topic.id %>/editar" class="forum-action-link">Editar topico</a>
                <% } %>

                <% if (canDeleteOwnTopic) { %>
                  <form action="/forum/topico/<%= topic.id %>/apagar" method="POST" data-confirm-action="Apagar este topico?">
                    <button type="submit" class="danger">Apagar topico</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>

        <% if (topic.category.slug === "denuncias") { %>
          <div class="forum-report-summary">
            <h2>Detalhes da denuncia</h2>

            <div class="forum-report-grid">
              <div>
                <span>Acusado</span>
                <strong><%= topic.reportAccusedNick || "Nao informado" %></strong>
              </div>

              <div>
                <span>Motivo</span>
                <strong><%= topic.reportReason || "Nao informado" %></strong>
              </div>

              <div>
                <span>Autor</span>
                <strong><%= displayUserName(topic.author) %></strong>
              </div>

              <div>
                <span>Status</span>
                <strong><%= topicStatusLabel(topic.status) %></strong>
              </div>

              <div>
                <span>Data</span>
                <strong><%= formatDateTime(topic.createdAt) %></strong>
              </div>

              <div>
                <span>Respostas da staff</span>
                <strong><%= topic.posts.length %></strong>
              </div>
            </div>

            <div class="forum-report-evidence">
              <span>Provas</span>
              <p><%- renderFormattedUserText(topic.reportEvidence || "Nenhuma prova informada.") %></p>
            </div>

            <div class="forum-report-decision">
              <span>Decisao da staff</span>
              <p>Decisao da staff em breve. Acompanhe as respostas oficiais neste topico.</p>
            </div>
          </div>
        <% } %>

        <%- include("../partials/forum-post-card", {
          author: topic.author,
          content: topic.content,
          postedAt: topic.createdAt,
          postNumber: 1,
          dateLabel: "Postado em",
          editHref: canEditOwnTopic ? `/forum/topico/${topic.id}/editar` : null,
          deleteAction: canDeleteOwnTopic ? `/forum/topico/${topic.id}/apagar` : null,
          deleteLabel: "Apagar topico"
        }) %>

        <% topic.posts.forEach((post, index) => { %>
  <%- include("../partials/forum-post-card", {
    author: post.author,
    content: post.content,
    postedAt: post.createdAt,
    postNumber: index + 2,
    dateLabel: "Respondido em",
    isReply: true,
    editHref: post.canEditPost ? `/forum/resposta/${post.id}/editar` : null,
    deleteAction: post.canDeletePost ? `/forum/resposta/${post.id}/apagar` : null,
    deleteLabel: "Apagar resposta"
  }) %>
<% }) %>

        <div class="forum-reply-form-card">
          <% if (replyError) { %>
            <div class="forum-permission-alert">
              <strong>Topico fechado</strong>
              <span><%= replyError %></span>
            </div>
          <% } %>

          <% if (topic.status === "CLOSED" || topic.status === "ARCHIVED") { %>
            <h2>Respostas bloqueadas</h2>
            <p>Este topico esta fechado ou arquivado e nao aceita novas respostas.</p>
          <% } else if (isPlayerLogged) { %>
            <h2>Responder topico</h2>

            <form action="/forum/topico/<%= topic.id %>/responder" method="POST" class="forum-form">
              <div class="form-group">
                <label>Sua resposta</label>

                <%- include("../partials/forum-editor-toolbar", {
                  textareaId: "content",
                  previewId: "replyPreview",
                  value: ""
                }) %>
              </div>

              <div class="forum-reply-actions">
                <button
                  type="submit"
                  class="btn-primary forum-submit-btn"
                  data-confirm-action="Enviar esta resposta?"
                >
                  Enviar resposta
                </button>
              </div>
            </form>
          <% } else { %>
            <h2>Entre para responder</h2>
            <p>Voce precisa estar logado para participar deste topico.</p>
            <a href="/entrar" class="btn-primary">Entrar na conta</a>
          <% } %>
        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
  <script src="/js/forumEditor.js"></script>

</body>
</html>
