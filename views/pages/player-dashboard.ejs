<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section">
      <div class="container">

        <div class="dashboard-v2-hero">
          <div class="dashboard-v2-profile">
            <a href="/perfil/<%= user.id %>" class="dashboard-v2-avatar">
              <% if (user.avatarUrl) { %>
                <img
                  src="<%= user.avatarUrl %>"
                  alt="Avatar de <%= user.name %>"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                >
                <span style="display:none;"><%= user.name.charAt(0).toUpperCase() %></span>
              <% } else { %>
                <span><%= user.name.charAt(0).toUpperCase() %></span>
              <% } %>
            </a>

            <div>
              <span class="section-tag">Meu painel</span>
              <h1>Bem-vindo, <%= user.name %></h1>
              <p>
                Acompanhe seu perfil, suas medalhas, topicos, denuncias,
                respostas recentes e atalhos principais da Central SurvivalZ.
              </p>

              <div class="dashboard-v2-badges">
                <span class="role-badge role-<%= user.role.toLowerCase() %>"><%= roleLabel(user.role) %></span>
                <span>Nick: <%= user.sampNick || "Nao informado" %></span>
                <span>Reputacao: <%= user.reputation || 0 %></span>
              </div>
            </div>
          </div>

          <a href="/sair" class="btn-secondary">Sair da conta</a>
        </div>

        <div class="dashboard-v2-quick-links">
          <a href="/perfil/editar">Editar perfil</a>
          <a href="/perfil/<%= user.id %>">Meu perfil</a>
          <a href="/comunidade">Comunidade</a>
          <a href="/forum/categoria/denuncias/novo">Criar denuncia</a>
          <a href="/forum">Forum</a>
          <a href="/loja">Loja</a>
        </div>

        <div class="player-dashboard-grid">
          <div class="player-panel-card">
            <span>☣</span>
            <h2>Perfil</h2>
            <p>
              <strong>E-mail:</strong> <%= user.email %><br>
              <strong>Discord:</strong> <%= user.discord || "Nao informado" %><br>
              <strong>Cargo:</strong> <%= roleLabel(user.role) %>
            </p>
          </div>

          <div class="player-panel-card">
            <span>◆</span>
            <h2>Medalhas recentes</h2>

            <% if (!user.medals || user.medals.length === 0) { %>
              <p>Suas medalhas aparecerao aqui quando forem concedidas pela staff.</p>
            <% } else { %>
              <div class="dashboard-v2-medals">
                <% user.medals.forEach((userMedal) => { %>
                  <span
                    class="forum-post-mini-medal medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
                    title="<%= userMedal.medal.name %>"
                  >
                    <%= userMedal.medal.icon || "★" %>
                  </span>
                <% }) %>
              </div>
            <% } %>
          </div>

          <div class="player-panel-card">
            <span>▣</span>
            <h2>Topicos</h2>
            <p>Voce possui <strong><%= topics.length %></strong> topico(s) publico(s) recente(s).</p>
            <a href="/forum">Acessar forum</a>
          </div>

          <div class="player-panel-card">
            <span>!</span>
            <h2>Denuncias</h2>
            <p>Voce possui <strong><%= reports.length %></strong> denuncia(s) recente(s).</p>
            <a href="/forum/categoria/denuncias">Ver denuncias</a>
          </div>
        </div>

        <div class="player-dashboard-content-grid dashboard-v2-content-grid">
          <div class="player-dashboard-list-card">
            <div class="player-list-header">
              <h2>Topicos recentes</h2>
              <a href="/forum/categoria/comunidade/novo">Criar topico</a>
            </div>

            <% if (topics.length === 0) { %>
              <p class="player-empty-text">Voce ainda nao criou topicos publicos.</p>
            <% } %>

            <% topics.forEach((topic) => { %>
              <a href="/forum/topico/<%= topic.id %>" class="player-dashboard-topic-item">
                <div>
                  <strong><%= topic.title %></strong>
                  <span><%= topic.category.name %> • <%= topic._count.posts %> resposta(s)</span>
                </div>

                <small><%= topicStatusLabel(topic.status) %></small>
              </a>
            <% }) %>
          </div>

          <div class="player-dashboard-list-card">
            <div class="player-list-header">
              <h2>Denuncias recentes</h2>
              <a href="/forum/categoria/denuncias/novo">Criar denuncia</a>
            </div>

            <% if (reports.length === 0) { %>
              <p class="player-empty-text">Voce ainda nao abriu nenhuma denuncia.</p>
            <% } %>

            <% reports.forEach((report) => { %>
              <a href="/forum/topico/<%= report.id %>" class="player-dashboard-topic-item">
                <div>
                  <strong><%= report.title %></strong>
                  <span>Acusado: <%= report.reportAccusedNick || "Nao informado" %></span>
                </div>

                <small><%= topicStatusLabel(report.status) %></small>
              </a>
            <% }) %>
          </div>

          <div class="player-dashboard-list-card dashboard-v2-wide-card">
            <div class="player-list-header">
              <h2>Respostas recentes</h2>
              <span><%= repliesCount %> resposta(s)</span>
            </div>

            <% if (recentReplies.length === 0) { %>
              <p class="player-empty-text">Voce ainda nao respondeu topicos do forum.</p>
            <% } %>

            <% recentReplies.forEach((reply) => { %>
              <a href="/forum/topico/<%= reply.topic.id %>" class="player-dashboard-topic-item">
                <div>
                  <strong><%= reply.topic.title %></strong>
                  <span><%= reply.topic.category.name %> • respondido em <%= formatDate(reply.createdAt) %></span>
                </div>
              </a>
            <% }) %>
          </div>
        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
