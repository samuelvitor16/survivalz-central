<link rel="stylesheet" href="/css/pages/mobile3.css">
<link rel="stylesheet" href="/css/pages/mobile-fix.css?v=20260614-2">
<header class="main-header sz-header">
  <%
    const canSeeStaffLinks = isStaffRole(playerRole);
    const sessionUser = {
      id: currentPlayerId,
      name: playerName,
      sampNick: playerName,
      avatarUrl: playerAvatarUrl,
      role: playerRole || "PLAYER"
    };
    const profileLabel = isPlayerLogged ? displayUserName(sessionUser) : "Conta";
    const profileInitial = isPlayerLogged ? displayInitial(sessionUser) : "Z";
    const profileAvatarUrl = isPlayerLogged ? playerAvatarUrl : null;
  %>

  <div class="container sz-header-shell">
    <a href="/" class="sz-header-logo" aria-label="SurvivalZ">
      <img src="/images/logo/survivalz-logo.png" alt="SurvivalZ">
    </a>

    <button type="button" class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="sz-header-nav" id="mainNavbar" aria-label="Navegacao principal">
      <div class="sz-header-links">
        <a href="/">Inicio</a>
        <a href="/forum">Forum</a>
        <a href="/loja">Loja Beta</a>
        <a href="/equipe">Equipe</a>
        <a href="/servidor">Servidor</a>
        <% if (canSeeStaffLinks) { %>
          <a href="/staff">Staff</a>
        <% } %>
      </div>

      <div class="sz-header-actions">
        <a href="<%= discordInvite %>" target="_blank" rel="noopener noreferrer" class="btn-nav sz-discord-btn">
          <span class="sz-discord-mark" aria-hidden="true">D</span>
          <span>Discord</span>
        </a>

        <div class="nav-dropdown profile-dropdown sz-profile-dropdown">
          <button type="button" class="profile-menu-button" aria-label="Abrir menu de perfil" aria-expanded="false">
            <% if (profileAvatarUrl) { %>
              <img src="<%= profileAvatarUrl %>" alt="Perfil de <%= profileLabel %>" class="profile-menu-avatar-img">
            <% } else { %>
              <span class="profile-menu-avatar"><%= profileInitial %></span>
            <% } %>
          </button>

          <div class="nav-dropdown-menu profile-dropdown-menu sz-profile-card">
            <% if (isPlayerLogged) { %>
              <div class="sz-profile-card-head">
                <% if (profileAvatarUrl) { %>
                  <img src="<%= profileAvatarUrl %>" alt="Perfil de <%= profileLabel %>" class="profile-menu-avatar-img large">
                <% } else { %>
                  <span class="profile-menu-avatar large"><%= profileInitial %></span>
                <% } %>
                <div>
                  <strong><%= profileLabel %></strong>
                  <small><%= roleLabel(playerRole) %></small>
                </div>
              </div>

              <a href="/perfil/<%= currentPlayerId %>">Meu perfil</a>
              <a href="/perfil/editar">Editar perfil</a>
              <a href="/painel/pedidos">Meus pedidos</a>

              <a href="/sair" class="logout-link">Sair</a>
            <% } else { %>
              <div class="sz-profile-card-head">
                <span class="profile-menu-avatar large">Z</span>
                <div>
                  <strong>Visitante</strong>
                  <small>Entre para acessar o perfil</small>
                </div>
              </div>

              <a href="/entrar">Entrar</a>
              <a href="/cadastrar">Criar conta</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuBtn = document.getElementById("mobileMenuBtn");
    const navbar = document.getElementById("mainNavbar");

    if (menuBtn && navbar) {
      menuBtn.addEventListener("click", () => {
        const isOpen = navbar.classList.toggle("is-open");
        menuBtn.classList.toggle("is-open", isOpen);
        menuBtn.setAttribute("aria-expanded", String(isOpen));
      });
    }

    document.querySelectorAll(".sz-profile-dropdown > button").forEach((button) => {
      button.addEventListener("click", (event) => {
        const dropdown = button.closest(".sz-profile-dropdown");
        if (!dropdown) return;

        event.preventDefault();
        const isOpen = dropdown.classList.toggle("open");
        button.setAttribute("aria-expanded", String(isOpen));
      });
    });

    document.addEventListener("click", (event) => {
      document.querySelectorAll(".sz-profile-dropdown.open").forEach((dropdown) => {
        if (!dropdown.contains(event.target)) {
          dropdown.classList.remove("open");
          const button = dropdown.querySelector(".profile-menu-button");
          if (button) button.setAttribute("aria-expanded", "false");
        }
      });
    });
  });
</script>
