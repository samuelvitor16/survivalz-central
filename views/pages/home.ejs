  </svg>
</span>
      <div>
        <strong>Discord</strong>
        <small>Comunidade e suporte</small>
      </div>
    </a>

    <a href="https://www.instagram.com/survivalzbr/" target="_blank" rel="noopener noreferrer" class="home-social-card instagram">
      <span class="home-social-icon" aria-hidden="true">
  <svg viewBox="0 0 24 24">
    <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95Zm8.95 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 6.7A5.3 5.3 0 1 1 6.7 12 5.3 5.3 0 0 1 12 6.7Zm0 1.8A3.5 3.5 0 1 0 15.5 12 3.5 3.5 0 0 0 12 8.5Z"/>
  </svg>
</span>
      <div>
        <strong>Instagram</strong>
        <small>Novidades e mídia</small>
      </div>
    </a>

    <a href="https://www.tiktok.com/@survivalzbr" target="_blank" rel="noopener noreferrer" class="home-social-card tiktok">
      <span class="home-social-icon" aria-hidden="true">
  <svg viewBox="0 0 24 24">
    <path d="M14.5 2c.54 1.7 1.78 3.04 3.5 3.6V8a7.08 7.08 0 0 1-3.5-.93v6.11A5.18 5.18 0 1 1 9.32 8v2.65a2.6 2.6 0 1 0 2.58 2.6V2Z"/>
  </svg>
</span>
      <div>
        <strong>TikTok</strong>
        <small>Clipes da zona</small>
      </div>
    </a>

    <a href="#" target="_blank" rel="noopener noreferrer" class="home-social-card youtube">
      <span class="home-social-icon" aria-hidden="true">
  <svg viewBox="0 0 24 24">
