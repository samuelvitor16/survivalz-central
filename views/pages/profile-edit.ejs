<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section sz-profile-editor">
      <div class="container">

        <div class="player-dashboard-header sz-profile-editor-header">
          <div>
            <span class="section-tag">Editar perfil</span>
            <h1>Personalize seu perfil</h1>
            <p>
              Ajuste avatar, capa, bio, assinatura e informacoes publicas do seu perfil.
            </p>
          </div>

          <a href="/perfil/<%= user.id %>" class="btn-secondary">
            Ver perfil publico
          </a>
        </div>

        <div class="sz-profile-editor-layout">
          <div class="sz-profile-editor-card">
            <% if (error) { %>
              <div class="player-auth-error">
                <%= error %>
              </div>
            <% } %>

            <% if (success) { %>
              <div class="sz-profile-editor-success">
                <%= success %>
              </div>
            <% } %>

            <div class="sz-profile-editor-upload-message" data-profile-upload-message role="status" aria-live="polite" hidden></div>

            <form action="/perfil/editar" method="POST" class="player-auth-form sz-profile-editor-form">
              <div class="sz-profile-editor-grid">
                <div class="form-group">
                  <label for="sampNick">Nick no servidor</label>
                  <input type="text" id="sampNick" name="sampNick" value="<%= user.sampNick || '' %>" maxlength="40" required>
                </div>

                <div class="form-group">
                  <label for="discord">Discord</label>
                  <input type="text" id="discord" name="discord" value="<%= user.discord || '' %>" maxlength="80">
                </div>

                <div class="form-group">
                  <label for="location">Localizacao / faccao / grupo</label>
                  <input
                    type="text"
                    id="location"
                    name="location"
                    value="<%= user.location || '' %>"
                    maxlength="80"
                    placeholder="Ex: Zona Norte, Sobrevivente solo, Cla..."
                  >
                </div>
              </div>

              <div class="sz-profile-editor-media-grid">
                <article class="sz-profile-editor-media-card">
                  <div class="sz-profile-editor-media-head">
                    <div>
                      <span>Avatar</span>
                      <strong>Imagem quadrada do jogador</strong>
                    </div>
                    <small>PNG, JPG, WEBP ou GIF ate 3MB</small>
                  </div>

                  <div class="sz-profile-editor-avatar-preview">
                    <% if (user.avatarUrl) { %>
                      <img id="avatarCardPreview" src="<%= user.avatarUrl %>" alt="Preview do avatar">
                      <span id="avatarCardFallback" style="display:none;"><%= displayInitial(user) %></span>
                    <% } else { %>
                      <img id="avatarCardPreview" src="" alt="Preview do avatar" style="display:none;">
                      <span id="avatarCardFallback"><%= displayInitial(user) %></span>
                    <% } %>
                  </div>

                  <div class="form-group">
                    <label for="avatarUrl">URL do avatar</label>
                    <input
                      type="text"
                      inputmode="url"
                      id="avatarUrl"
                      name="avatarUrl"
                      value="<%= user.avatarUrl || '' %>"
                      placeholder="https://... ou /uploads/profile/arquivo.png"
                    >
                  </div>

                  <input
                    type="file"
                    id="avatarUpload"
                    class="sz-profile-editor-file-input"
                    accept="image/png,image/jpeg,image/jpg,image/webp,image/gif"
                    data-profile-upload="avatar"
                    data-profile-endpoint="/uploads/profile/avatar"
                    data-profile-input="avatarUrl"
                    data-profile-preview="avatarCardPreview,avatarPreview"
                    data-profile-fallback="avatarCardFallback,avatarFallback"
                    data-profile-max-size="3145728"
                  >
                  <label for="avatarUpload" class="sz-profile-editor-upload-btn">Enviar avatar</label>
                </article>

                <article class="sz-profile-editor-media-card sz-profile-editor-media-card-wide">
                  <div class="sz-profile-editor-media-head">
                    <div>
                      <span>Banner</span>
                      <strong>Capa horizontal do perfil</strong>
                    </div>
                    <small>PNG, JPG, WEBP ou GIF ate 5MB</small>
                  </div>

                  <div class="sz-profile-editor-banner-preview">
                    <% if (user.bannerUrl) { %>
                      <img id="bannerCardPreview" src="<%= user.bannerUrl %>" alt="Preview do banner">
                    <% } else { %>
                      <img id="bannerCardPreview" src="" alt="Preview do banner" style="display:none;">
                    <% } %>
                    <span>Banner 1400x350</span>
                  </div>

                  <div class="form-group">
                    <label for="bannerUrl">URL do banner/capa</label>
                    <input
                      type="text"
                      inputmode="url"
                      id="bannerUrl"
                      name="bannerUrl"
                      value="<%= user.bannerUrl || '' %>"
                      placeholder="https://... ou /uploads/profile/arquivo.webp"
                    >
                  </div>

                  <input
                    type="file"
                    id="bannerUpload"
                    class="sz-profile-editor-file-input"
                    accept="image/png,image/jpeg,image/jpg,image/webp,image/gif"
                    data-profile-upload="banner"
                    data-profile-endpoint="/uploads/profile/banner"
                    data-profile-input="bannerUrl"
                    data-profile-preview="bannerCardPreview,bannerPreviewImage"
                    data-profile-max-size="5242880"
                  >
                  <label for="bannerUpload" class="sz-profile-editor-upload-btn">Enviar banner</label>
                </article>
              </div>

              <div class="form-group">
                <label for="bio">Bio</label>
                <textarea
                  id="bio"
                  name="bio"
                  maxlength="800"
                  placeholder="Fale sobre voce, seu estilo de jogo, cla ou historia no servidor..."
                ><%= user.bio || '' %></textarea>
                <small class="sz-profile-editor-hint">Maximo recomendado: 800 caracteres.</small>
              </div>

              <article class="sz-profile-editor-media-card sz-profile-editor-signature-card">
                <div class="sz-profile-editor-media-head">
                  <div>
                    <span>Assinatura</span>
                    <strong>Texto e imagem exibidos nas postagens</strong>
                  </div>
                  <small>Imagem ate 5MB</small>
                </div>

                <div class="form-group">
                  <label for="signatureText">Assinatura em texto</label>
                  <textarea
                    id="signatureText"
                    name="signatureText"
                    maxlength="350"
                    placeholder="Frase, lema, cla, recado ou mini apresentacao..."
                  ><%= user.signatureText || '' %></textarea>
                  <small class="sz-profile-editor-hint">Maximo recomendado: 350 caracteres.</small>
                </div>

                <div class="sz-profile-editor-signature-preview">
                  <strong>Preview da assinatura</strong>
                  <% if (user.signatureText) { %>
                    <p id="signatureTextCardPreview"><%- renderUserText(user.signatureText) %></p>
                  <% } else { %>
                    <p id="signatureTextCardPreview">Texto da assinatura.</p>
                  <% } %>

                  <% if (user.signatureImageUrl) { %>
                    <img id="signatureImageCardPreview" src="<%= user.signatureImageUrl %>" alt="Preview da assinatura">
                  <% } else { %>
                    <img id="signatureImageCardPreview" src="" alt="Preview da assinatura" style="display:none;">
                  <% } %>
                </div>

                <div class="form-group">
                  <label for="signatureImageUrl">URL da imagem de assinatura</label>
                  <input
                    type="text"
                    inputmode="url"
                    id="signatureImageUrl"
                    name="signatureImageUrl"
                    value="<%= user.signatureImageUrl || '' %>"
                    placeholder="https://... ou /uploads/profile/arquivo.gif"
                  >
                </div>

                <input
                  type="file"
                  id="signatureUpload"
                  class="sz-profile-editor-file-input"
                  accept="image/png,image/jpeg,image/jpg,image/webp,image/gif"
                  data-profile-upload="signature"
                  data-profile-endpoint="/uploads/profile/signature"
                  data-profile-input="signatureImageUrl"
                  data-profile-preview="signatureImageCardPreview,signatureImagePreview"
                  data-profile-max-size="5242880"
                >
                <label for="signatureUpload" class="sz-profile-editor-upload-btn">Enviar imagem de assinatura</label>
              </article>

              <button type="submit" class="btn-primary player-auth-btn sz-profile-editor-submit">
                Salvar perfil
              </button>
            </form>
          </div>

          <aside class="sz-profile-editor-preview-card">
            <h2>Preview do perfil</h2>

            <div class="sz-profile-editor-banner-preview sz-profile-editor-preview-banner">
              <% if (user.bannerUrl) { %>
                <img id="bannerPreviewImage" src="<%= user.bannerUrl %>" alt="Preview da capa">
              <% } else { %>
                <img id="bannerPreviewImage" src="" alt="Preview da capa" style="display:none;">
              <% } %>
              <span>Banner 1400x350</span>
            </div>

            <div class="sz-profile-editor-avatar-preview sz-profile-editor-preview-avatar">
              <% if (user.avatarUrl) { %>
                <img id="avatarPreview" src="<%= user.avatarUrl %>" alt="Preview do avatar">
                <span id="avatarFallback" style="display:none;"><%= displayInitial(user) %></span>
              <% } else { %>
                <img id="avatarPreview" src="" alt="Preview do avatar" style="display:none;">
                <span id="avatarFallback"><%= displayInitial(user) %></span>
              <% } %>
            </div>

            <div class="sz-profile-editor-signature-preview">
              <strong>Assinatura</strong>
              <% if (user.signatureText) { %>
                <p id="signatureTextPreview"><%- renderUserText(user.signatureText) %></p>
              <% } else { %>
                <p id="signatureTextPreview">Texto da assinatura.</p>
              <% } %>

              <% if (user.signatureImageUrl) { %>
                <img id="signatureImagePreview" src="<%= user.signatureImageUrl %>" alt="Preview da assinatura">
              <% } else { %>
                <img id="signatureImagePreview" src="" alt="Preview da assinatura" style="display:none;">
              <% } %>
            </div>
          </aside>
        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

  <script src="/js/profileEditor.js" defer></script>
</body>
</html>
