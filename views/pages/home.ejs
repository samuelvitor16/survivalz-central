        </article>

        <article class="home-shot-card">
          <img src="/images/server-shots/shot-5.png" alt="Registro SurvivalZ">
          <div>
            <span>Safezone</span>
            <strong>Um respiro antes da próxima rota</strong>
          </div>
        </article>

        <article class="home-shot-card">
          <img src="/images/server-shots/shot-6.png" alt="Registro SurvivalZ">
          <div>
            <span>Risco</span>
            <strong>Nem todo encontro termina bem</strong>
          </div>
        </article>

        <article class="home-shot-card is-wide">
          <img src="/images/server-shots/shot-7.png" alt="Registro SurvivalZ">
          <div>
            <span>Mapa</span>
            <strong>Los Santos em ruínas</strong>
          </div>
        </article>

        <article class="home-shot-card">
          <img src="/images/server-shots/shot-8.png" alt="Registro SurvivalZ">
          <div>
            <span>Beta</span>
            <strong>A preparação continua</strong>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>
  </main>
      <div class="home-news-modal" id="homeNewsModal" hidden>
  <div class="home-news-modal-backdrop" data-news-close></div>

  <article class="home-news-modal-card">
    <button type="button" class="home-news-modal-close" data-news-close>×</button>

    <div class="home-news-modal-image">
      <img src="/images/home/hero-bg.png" alt="" id="homeNewsModalImage">
    </div>

    <div class="home-news-modal-content">
      <span id="homeNewsModalCategory">Notícia</span>
      <h2 id="homeNewsModalTitle">Título</h2>

      <small id="homeNewsModalMeta">Data • Autor</small>

      <div class="home-news-modal-text" id="homeNewsModalText"></div>

      <a href="/forum" id="homeNewsModalUrl">Ler no fórum</a>
    </div>
  </article>
</div>
  <%- include("../partials/footer") %>
  <script src="/js/homeAnimations.js"></script>
<script src="/js/homeNewsModal.js"></script>
<script src="/js/serverShotsCarousel.js"></script>
</body>
</html>
