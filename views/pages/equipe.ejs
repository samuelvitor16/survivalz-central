<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/forum.css">
  <link rel="stylesheet" href="/css/pages/gestao.css">
  <link rel="stylesheet" href="/css/pages/equipe.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="team-page">
      <div class="container">

        <header class="team-hero">
          <div class="team-hero-content">
            <span class="section-tag">Equipe oficial</span>
            <h1>Equipe SurvivalZ</h1>
            <p>
              Conheça os responsáveis pela direção, administração, moderação
              e suporte da comunidade SurvivalZ.
            </p>

            <div class="team-hero-badges">
              <span>Gestão Principal</span>
              <span>Desenvolvimento</span>
              <span>Direção</span>
              <span>Operacional</span>
            </div>
          </div>

          <div class="team-hero-card">
            <span>Central da equipe</span>
            <strong><%= team.length %></strong>
            <small>membro(s) cadastrados</small>
          </div>
        </header>

      </div>

      <section class="sz-management-section team-management-block">
        <div class="container">
          <div class="sz-management-section-header">
            <span class="sz-management-kicker">Equipe principal</span>
            <h2>Responsáveis pelo projeto</h2>
            <p>
              A gestão principal acompanha a parte técnica, a organização da comunidade
              e o desenvolvimento da Central SurvivalZ.
            </p>
          </div>

          <div class="sz-management-team-grid">
            <article class="sz-manager-card lead sz-manager-card-with-art">
              <div class="sz-manager-art lead-art">
                <img src="/images/team/lead-skin94.png" alt="Personagem do LEAD no SurvivalZ">
              </div>

              <div class="sz-manager-info">
                <span>Fundador • Desenvolvimento • Servidor</span>
                <h3>LEAD</h3>

                <p>
                  Responsável por sistemas, estrutura técnica, desenvolvimento do servidor
                  e evolução da base principal do SurvivalZ.
                </p>

                <div class="sz-manager-tags">
                  <strong>Servidor</strong>
                  <strong>Sistemas</strong>
                  <strong>Desenvolvimento</strong>
                </div>
              </div>
            </article>

            <article class="sz-manager-card samuel sz-manager-card-with-art">
              <div class="sz-manager-art">
                <img src="/images/team/samuel-skin160.png" alt="Personagem de Samuel no SurvivalZ">
              </div>

              <div class="sz-manager-info">
                <span>Gestão • Comunidade • Organização</span>
                <h3>DybalaX</h3>

                <p>
                  Responsável pela organização da comunidade, comunicação, suporte,
                  estrutura da Central e acompanhamento dos jogadores.
                </p>

                <div class="sz-manager-tags">
                  <strong>Comunidade</strong>
                  <strong>Suporte</strong>
                  <strong>Central</strong>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <div class="container">

        <%
          const sortedTeam = [...team].sort((a, b) => {
            return rolePower(b.role) - rolePower(a.role);
          });

          const teamGroups = [
            {
              title: "Desenvolvimento",
              subtitle: "Base técnica do projeto",
              description: "Responsável pela estrutura técnica, sistemas, manutenção e evolução da Central SurvivalZ.",
              roles: ["DESENVOLVEDOR", "OWNER"]
            },
            {
              title: "Direção e Gestão",
              subtitle: "Organização interna",
              description: "Responsáveis pela direção, organização interna, decisões administrativas e gestão geral do projeto.",
              roles: ["DIRETOR", "SUB_DIRETOR", "GERENTE"]
            },
            {
              title: "Equipe Operacional",
              subtitle: "Moderação e atendimento",
              description: "Equipe responsável pelo suporte aos jogadores, denúncias, fiscalização, atendimento e organização da comunidade.",
              roles: ["COORDENADOR", "SUPERVISOR", "ADMINISTRADOR", "MODERADOR", "ESTAGIARIO", "SUPORTE", "ADMIN", "STAFF"]
            }
          ];

          const memberRankMeta = {
            desenvolvedor: { icon: "💻", level: "5000", tier: "NÚCLEO", className: "rank-core" },
            diretor: { icon: "👑", level: "2002", tier: "DIREÇÃO", className: "rank-director" },
            sub_diretor: { icon: "⭐", level: "2001", tier: "DIREÇÃO", className: "rank-subdirector" },
            gerente: { icon: "💼", level: "2000", tier: "GESTÃO", className: "rank-manager" },
            coordenador: { icon: "📌", level: "006", tier: "OPERAÇÃO", className: "rank-coordinator" },
            supervisor: { icon: "👁", level: "005", tier: "OPERAÇÃO", className: "rank-supervisor" },
            administrador: { icon: "🛡️", level: "004", tier: "STAFF", className: "rank-admin" },
            moderador: { icon: "⚔️", level: "003", tier: "STAFF", className: "rank-mod" },
            estagiario: { icon: "🧪", level: "002", tier: "STAFF", className: "rank-trainee" },
            suporte: { icon: "🎧", level: "001", tier: "SUPORTE", className: "rank-support" },
            sobrevivente: { icon: "☣", level: "000", tier: "SOBREVIVENTE", className: "rank-player" },
            premium: { icon: "💎", level: "010", tier: "PREMIUM", className: "rank-premium" },
            beta_tester: { icon: "🧪", level: "020", tier: "BETA", className: "rank-beta" },
            youtuber: { icon: "▶️", level: "030", tier: "CRIADOR", className: "rank-youtuber" },

            owner: { icon: "💻", level: "5000", tier: "NÚCLEO", className: "rank-core" },
            admin: { icon: "🛡️", level: "004", tier: "STAFF", className: "rank-admin" },
            staff: { icon: "🎧", level: "001", tier: "SUPORTE", className: "rank-support" }
          };
        %>

        <section class="team-list-section">
          <% teamGroups.forEach((group) => { %>
            <% const members = sortedTeam.filter((member) => group.roles.includes(member.role)); %>

            <section class="team-group">
              <div class="team-group-head">
                <div>
                  <span class="section-tag"><%= group.subtitle %></span>
                  <h2><%= group.title %></h2>
                  <p><%= group.description %></p>
                </div>

                <strong><%= members.length %></strong>
              </div>

              <% if (members.length === 0) { %>
                <div class="team-empty">
                  Nenhum membro cadastrado nesta área ainda.
                </div>
              <% } %>

              <% if (members.length > 0) { %>
                <div class="team-grid">
                  <% members.forEach((member) => { %>
                    <%
                      const memberRoleKey = roleClass(member.role);
                      const memberRank = memberRankMeta[memberRoleKey] || memberRankMeta.sobrevivente;
                    %>

                    <article class="team-rank-card <%= memberRank.className %>">
                      <div class="team-rank-card-top">
                        <a href="/perfil/<%= member.id %>" class="team-rank-avatar">
                          <% if (member.avatarUrl) { %>
                            <img
                              src="<%= member.avatarUrl %>"
                              alt="Avatar de <%= displayUserName(member) %>"
                              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                            >
                            <span style="display:none;"><%= displayInitial(member) %></span>
                          <% } else { %>
                            <span><%= displayInitial(member) %></span>
                          <% } %>
                        </a>

                        <div class="team-rank-namebox">
                          <h3><%= displayUserName(member) %></h3>
                          <p><%= member.bio ? plainTextExcerpt(member.bio, 90) : "Membro da equipe SurvivalZ." %></p>
                        </div>
                      </div>

                      <div class="sz-author-rank-v3 sz-author-rank-<%= memberRoleKey %> <%= memberRank.className %>">
                        <div class="sz-rank-topline">
                          <span><%= memberRank.tier %></span>
                          <strong>NV <%= memberRank.level %></strong>
                        </div>

                        <div class="sz-rank-main">
                          <div class="sz-rank-emblem">
                            <span><%= memberRank.icon %></span>
                          </div>

                          <div class="sz-rank-info">
                            <small>Cargo SurvivalZ</small>
                            <strong><%= roleDisplayLabel(member.role) %></strong>
                          </div>
                        </div>

                        <div class="sz-rank-authority">
                          <span>Autoridade</span>
                          <div>
                            <i></i>
                            <i></i>
                            <i></i>
                            <i></i>
                            <i></i>
                          </div>
                        </div>
                      </div>

                      <div class="team-rank-footer">
                        <div class="team-rank-medals">
                          <% if (member.medals && member.medals.length > 0) { %>
                            <% member.medals.slice(0, 5).forEach((userMedal) => { %>
                              <span
                                class="medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
                                title="<%= medalTooltip(userMedal) %>"
                              >
                                <%= userMedal.medal.icon || "🏅" %>
                              </span>
                            <% }) %>
                          <% } else { %>
                            <small>Sem insígnias</small>
                          <% } %>
                        </div>

                        <a href="/perfil/<%= member.id %>" class="team-rank-profile-link">
                          Ver perfil
                        </a>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </section>
          <% }) %>
        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
