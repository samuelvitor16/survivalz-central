<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/forum.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="forum-section">
      <div class="container">

        <section class="sz-staff-hero">
          <div>
            <span class="sz-staff-kicker">Central Staff</span>
            <h1>Moderacao SurvivalZ</h1>

            <p>
              Hub interno para acompanhar denuncias, revisar topicos e acessar as acoes permitidas
              para o seu cargo atual: <strong><%= roleLabel(playerRole) %></strong>.
            </p>
          </div>

          <div class="sz-staff-hero-actions">
            <a href="/forum/moderacao/denuncias">Denuncias</a>
            <a href="/forum">Forum publico</a>
            <% if (rolePower(playerRole) >= 4) { %>
              <a href="/admin">Painel Desenvolvedor</a>
            <% } %>
          </div>
        </section>

        <section class="sz-staff-overview sz-staff-overview-compact">
          <article>
            <span>Topicos filtrados</span>
            <strong><%= overview.topicsCount %></strong>
            <small>Resultado do filtro atual</small>
          </article>

          <article>
            <span>Denuncias abertas</span>
            <strong><%= overview.openReports %></strong>
            <small>Casos aguardando analise</small>
          </article>
        </section>

        <section class="sz-staff-actions sz-staff-actions-unified">
          <a href="/forum/moderacao/denuncias">
            <span>!</span>
            <div>
              <strong>Denuncias</strong>
              <small>Analise casos privados e evidencias enviadas.</small>
            </div>
          </a>

          <a href="/forum/categoria/denuncias">
            <span>D</span>
            <div>
              <strong>Area de denuncias</strong>
              <small>Abrir a categoria protegida do forum.</small>
            </div>
          </a>

          <a href="/forum">
            <span>F</span>
            <div>
              <strong>Forum publico</strong>
              <small>Voltar para categorias e topicos da comunidade.</small>
            </div>
          </a>

          <% if (rolePower(playerRole) >= 4) { %>
            <a href="/forum/moderacao/medalhas">
              <span>M</span>
              <div>
                <strong>Medalhas</strong>
                <small>Gerenciar insignias dos jogadores.</small>
              </div>
            </a>

            <a href="/admin/pedidos">
              <span>P</span>
              <div>
                <strong>Pedidos</strong>
                <small>Acompanhar pedidos da Loja Beta.</small>
              </div>
            </a>

            <a href="/admin/usuarios">
              <span>U</span>
              <div>
                <strong>Usuarios</strong>
                <small>Buscar contas, perfis e atividade.</small>
              </div>
            </a>

            <a href="/admin/cargos">
              <span>C</span>
              <div>
                <strong>Cargos</strong>
                <small>Alterar roles com bloqueio do ultimo OWNER.</small>
              </div>
            </a>
          <% } %>
        </section>

        <nav class="sz-staff-filters">
          <a class="<%= status === 'ALL' ? 'active' : '' %>" href="/forum/moderacao">Todos</a>
          <a class="<%= status === 'OPEN' ? 'active' : '' %>" href="/forum/moderacao?status=OPEN">Abertos</a>
          <a class="<%= status === 'PINNED' ? 'active' : '' %>" href="/forum/moderacao?status=PINNED">Fixados</a>
          <a class="<%= status === 'CLOSED' ? 'active' : '' %>" href="/forum/moderacao?status=CLOSED">Fechados</a>
          <a class="<%= status === 'ARCHIVED' ? 'active' : '' %>" href="/forum/moderacao?status=ARCHIVED">Arquivados</a>
        </nav>

        <section class="sz-staff-panel">
          <div class="sz-staff-panel-header">
            <div>
              <span>Moderacao</span>
              <h2>Topicos encontrados</h2>
            </div>

            <strong><%= topics.length %> topico(s)</strong>
          </div>

          <% if (topics.length === 0) { %>
            <div class="sz-staff-empty">
              <h3>Nenhum topico encontrado</h3>
              <p>Nao ha topicos para este filtro. Use outro status ou volte para todos.</p>
            </div>
          <% } %>

          <div class="sz-staff-topic-list">
            <% topics.forEach((topic) => { %>
              <article class="sz-staff-topic-card">
                <div class="sz-staff-topic-main">
                  <div class="sz-staff-topic-badges">
                    <span class="sz-staff-status sz-staff-status-<%= topic.status.toLowerCase() %>">
                      <%= topicStatusLabel(topic.status) %>
                    </span>

                    <span class="sz-staff-category">
                      <%= topic.category.icon || "Z" %>
                      <%= topic.category.name %>
                    </span>
                  </div>

                  <h3>
                    <a href="/forum/topico/<%= topic.id %>">
                      <%= topic.title %>
                    </a>
                  </h3>

                  <p>
                    Autor: <strong><%= displayUserName(topic.author) %></strong>
                    - <%= topic._count.posts %> resposta(s)
                  </p>
                </div>

                <form
                  action="/forum/moderacao/topico/<%= topic.id %>/status"
                  method="POST"
                  class="sz-staff-topic-actions"
                >
                  <select name="status">
                    <option value="OPEN" <%= topic.status === "OPEN" ? "selected" : "" %>>Aberto</option>
                    <option value="CLOSED" <%= topic.status === "CLOSED" ? "selected" : "" %>>Fechado</option>
                    <option value="PINNED" <%= topic.status === "PINNED" ? "selected" : "" %>>Fixado</option>
                    <option value="ARCHIVED" <%= topic.status === "ARCHIVED" ? "selected" : "" %>>Arquivado</option>
                  </select>

                  <button type="submit">Salvar</button>

                  <a href="/forum/topico/<%= topic.id %>">Abrir</a>
                </form>
              </article>
            <% }) %>
          </div>
        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
