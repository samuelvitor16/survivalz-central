generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  PLAYER
  STAFF
  ADMIN
  OWNER
}

enum TopicStatus {
  OPEN
  CLOSED
  PINNED
  ARCHIVED
}

enum MedalRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  SPECIAL
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String
  discord      String?
  sampNick     String? @unique

  avatarUrl String?
  bannerUrl String?
  bio       String? @db.Text
  location  String?

  signatureText     String? @db.Text
  signatureImageUrl String?
  reputation        Int     @default(0)

  role     UserRole @default(PLAYER)
  isBanned Boolean  @default(false)

  topics ForumTopic[]
  posts  ForumPost[]

  medals        UserMedal[] @relation("UserMedals")
  medalsAwarded UserMedal[] @relation("AwardedMedals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ForumCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  color       String?
  position    Int     @default(0)
  isLocked    Boolean @default(false)

  topics ForumTopic[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forum_categories")
}

model ForumTopic {
  id      String @id @default(cuid())
  title   String
  slug    String
  content String @db.Text

  reportAccusedNick String?
  reportReason      String?
  reportEvidence    String? @db.Text

  status TopicStatus @default(OPEN)
  views  Int         @default(0)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])

  posts ForumPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@map("forum_topics")
}

model ForumPost {
  id      String @id @default(cuid())
  content String @db.Text

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  topicId String
  topic   ForumTopic @relation(fields: [topicId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forum_posts")
}

model Medal {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  icon        String?
  color       String?
  rarity      MedalRarity @default(COMMON)
  isActive    Boolean     @default(true)

  users UserMedal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medals")
}

model UserMedal {
  id String @id @default(cuid())

  userId String
  user   User   @relation("UserMedals", fields: [userId], references: [id])

  medalId String
  medal   Medal  @relation(fields: [medalId], references: [id])

  awardedById String?
  awardedBy   User?   @relation("AwardedMedals", fields: [awardedById], references: [id])

  reason String? @db.Text

  createdAt DateTime @default(now())

  @@unique([userId, medalId])
  @@map("user_medals")
}
