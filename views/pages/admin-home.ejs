<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/admin.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="admin-home-section">
      <div class="container">

        <section class="sz-dev-hero">
          <div>
            <span class="sz-dev-kicker">Painel Desenvolvedor</span>
            <h1>Central Dev SurvivalZ</h1>

            <p>
              Área principal para gestão da Central: loja beta, pedidos, fórum,
              denúncias, medalhas, usuários e futuras integrações com o servidor.
            </p>
          </div>

          <div class="sz-dev-access-card">
            <span>Nível de acesso</span>
            <strong>Desenvolvedor/Admin</strong>
            <small>Operação interna da Central</small>
          </div>
        </section>

        <section class="sz-dev-overview">
          <article>
            <span>Total de pedidos</span>
            <strong><%= totalOrders %></strong>
            <small>Pedidos enviados pela Loja Beta</small>
          </article>

          <article>
            <span>Pendentes</span>
            <strong><%= pendingOrders %></strong>
            <small>Aguardando análise</small>
          </article>

          <article>
            <span>Pagos</span>
            <strong><%= paidOrders %></strong>
            <small>Marcados como pagos</small>
          </article>

          <article>
            <span>Entregues</span>
            <strong><%= deliveredOrders %></strong>
            <small>Liberados manualmente</small>
          </article>

          <article>
            <span>Usuários</span>
            <strong><%= siteOverview.usersCount %></strong>
            <small>Contas registradas</small>
          </article>

          <article>
            <span>Fórum</span>
            <strong><%= siteOverview.topicsCount %></strong>
            <small>Tópicos criados</small>
          </article>

          <article>
            <span>Denúncias</span>
            <strong><%= siteOverview.reportsCount %></strong>
            <small>Casos registrados</small>
          </article>

          <article>
            <span>Medalhas</span>
            <strong><%= siteOverview.medalsCount %></strong>
            <small>Insígnias cadastradas</small>
          </article>
        </section>

        <section class="sz-dev-actions">
          <a href="/admin/pedidos">
            <span>R$</span>
            <div>
              <strong>Pedidos da Loja</strong>
              <small>Conferir compras, cupom, dados do comprador e status.</small>
            </div>
          </a>

          <a href="/forum/moderacao">
            <span>💬</span>
            <div>
              <strong>Hub Staff</strong>
              <small>Moderador central para tópicos, filtros e ações rápidas.</small>
            </div>
          </a>

          <a href="/forum/moderacao/denuncias">
            <span>⚠️</span>
            <div>
              <strong>Denúncias</strong>
              <small>Acompanhar casos privados, provas e movimentações.</small>
            </div>
          </a>

          <a href="/forum/moderacao/medalhas">
            <span>🏅</span>
            <div>
              <strong>Medalhas</strong>
              <small>Conceder e remover insígnias dos usuários.</small>
            </div>
          </a>

          <a href="/admin/usuarios">
            <span>👤</span>
            <div>
              <strong>Usuários</strong>
              <small>Buscar contas, ver atividade, pedidos vinculados e cargos.</small>
            </div>
          </a>

          <a href="/admin/cargos">
            <span>STAFF</span>
            <div>
              <strong>Equipe e cargos</strong>
              <small>Promover staff, ajustar admins e proteger o ultimo Owner.</small>
            </div>
          </a>

          <a href="#" class="is-disabled">
            <span>⚙️</span>
            <div>
              <strong>Configurações</strong>
              <small>Integrações, parâmetros, logs e sistemas futuros.</small>
            </div>
          </a>
        </section>

        <section class="sz-dev-content-grid" id="dados-backups">
          <article class="sz-dev-box">
            <div class="sz-dev-box-header">
              <div>
                <span>Dados e backups</span>
                <h2>Armazenamento atual</h2>
              </div>
            </div>

            <div class="sz-dev-summary-list">
              <div><strong>Banco principal</strong><span>MySQL via Prisma</span></div>
              <div><strong>Pedidos manuais</strong><span>data/orders.json</span></div>
              <div><strong>Uploads</strong><span>public/uploads</span></div>
            </div>
          </article>
        </section>

        <section class="sz-dev-content-grid">

          <article class="sz-dev-box">
            <div class="sz-dev-box-header">
              <div>
                <span>Operação atual</span>
                <h2>Resumo do site</h2>
              </div>
            </div>

            <div class="sz-dev-summary-list">
              <div>
                <strong>Loja Beta</strong>
                <span>Pedidos manuais ativos</span>
              </div>

              <div>
                <strong>Fórum</strong>
                <span>Moderação via Hub Staff</span>
              </div>

              <div>
                <strong>Dados do jogo</strong>
                <span>Campos preparados no banco</span>
              </div>

              <div>
                <strong>Integração SA-MP</strong>
                <span>Planejada para próxima fase</span>
              </div>
            </div>
          </article>

          <article class="sz-dev-box">
            <div class="sz-dev-box-header">
              <div>
                <span>Atalhos internos</span>
                <h2>Links rápidos</h2>
              </div>
            </div>

            <div class="sz-dev-summary-list">
              <a href="/loja">
                <strong>Loja pública</strong>
                <span>Ver vitrine da Loja Beta</span>
              </a>

              <a href="/forum">
                <strong>Forum</strong>
                <span>Ver atividade pública</span>
              </a>

              <a href="/forum/categoria/avisos-oficiais/novo">
                <strong>Novo aviso</strong>
                <span>Publicar comunicado oficial</span>
              </a>

              <a href="/admin/pedidos/export/json">
                <strong>Exportar pedidos</strong>
                <span>Baixar JSON da loja</span>
              </a>
            </div>
          </article>

        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
