<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <meta name="description" content="SurvivalZ e o portal oficial do servidor SA-MP pos-apocaliptico com Beta, forum, loja e comunidade.">
  <meta name="theme-color" content="#c40000">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/home.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="home-hero">
      <div class="home-hero-backdrop" aria-hidden="true"></div>

      <div class="container home-hero-inner">
        <div class="home-hero-copy">
          <img src="/images/logo/survivalz-logo.png" alt="SurvivalZ" class="home-hero-logo">
          <span class="home-kicker">SA-MP Survival Beta</span>
          <h1>Sobreviva. Evolua. Domine a zona.</h1>
          <p>
            Entre na zona pos-apocaliptica do SurvivalZ: forum, loja beta, suporte
            e comunidade em um so lugar.
          </p>

          <div class="home-hero-actions">
            <a href="/loja" class="btn-primary">Comprar Beta</a>
            <a href="/forum" class="btn-secondary">Forum</a>
            <a href="<%= discordInvite %>" target="_blank" rel="noopener noreferrer" class="btn-secondary">Discord</a>
          </div>
          
<div class="home-social-panel">
  <div class="home-social-panel-head">
    <span>Redes da comunidade</span>
    <strong>Acompanhe o SurvivalZ</strong>
  </div>

  <div class="home-social-grid">
    <a href="<%= discordInvite %>" target="_blank" rel="noopener noreferrer" class="home-social-card discord">
