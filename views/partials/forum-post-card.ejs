<article class="sz-post <%= typeof isReply !== 'undefined' && isReply ? 'sz-post-reply' : '' %>">

  <aside class="sz-author-panel">

    <a href="/perfil/<%= author.id %>" class="sz-author-avatar">
      <% if (author.avatarUrl) { %>
        <img
          src="<%= author.avatarUrl %>"
          alt="Avatar de <%= author.name %>"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        >

        <div class="sz-author-avatar-fallback" style="display:none;">
          <%= author.name.charAt(0).toUpperCase() %>
        </div>
      <% } else { %>
        <div class="sz-author-avatar-fallback">
          <%= author.name.charAt(0).toUpperCase() %>
        </div>
      <% } %>
    </a>

    <div class="sz-author-name">
      <%= author.name %>
    </div>

    <div class="sz-author-rank sz-author-rank-<%= author.role.toLowerCase() %>">
      <div class="sz-author-rank-icon">
        <% if (author.role === "OWNER") { %>
          👑
        <% } else if (author.role === "ADMIN") { %>
          🛡️
        <% } else if (author.role === "STAFF" || author.role === "MODERADOR") { %>
          ⚔️
        <% } else { %>
          ☣
        <% } %>
      </div>

      <div class="sz-author-rank-text">
        <span>Cargo</span>
        <strong><%= roleDisplayLabel(author.role) %></strong>
      </div>
    </div>

    <% if (author.medals && author.medals.length > 0) { %>
      <div class="sz-author-insignias">
        <span class="sz-author-box-title">Insígnias</span>

        <div class="sz-author-insignia-list">
          <% author.medals.slice(0, 6).forEach((userMedal) => { %>
            <span
              class="sz-author-insignia medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
              title="<%= medalTooltip(userMedal) %>"
              data-tooltip="<%= medalTooltip(userMedal) %>"
            >
              <%= userMedal.medal.icon || "🏅" %>
            </span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="sz-author-info-list">
      <div class="sz-author-info-row">
        <span>Nick</span>
        <strong><%= author.sampNick || "Não informado" %></strong>
      </div>

      <div class="sz-author-info-row">
        <span>Reputação</span>
        <strong><%= author.reputation || 0 %></strong>
      </div>

      <div class="sz-author-info-row">
        <span>Registro</span>
        <strong><%= formatDate(author.createdAt) %></strong>
      </div>
    </div>

    <div class="sz-author-stats">
      <div>
        <span>Tópicos</span>
        <strong><%= author._count ? author._count.topics : 0 %></strong>
      </div>

      <div>
        <span>Respostas</span>
        <strong><%= author._count ? author._count.posts : 0 %></strong>
      </div>
    </div>

    <a href="/perfil/<%= author.id %>" class="sz-author-profile-link">
      Ver perfil
    </a>

  </aside>

  <div class="sz-post-main">

    <div class="sz-post-top">
      <span><%= dateLabel %> <%= formatDate(postedAt) %></span>

      <div class="sz-post-actions">
        <% if (typeof editHref !== "undefined" && editHref) { %>
          <a
            href="<%= editHref %>"
            class="sz-post-action"
            title="Editar"
            aria-label="Editar publicação"
          >
            ✎
          </a>
        <% } %>

        <% if (typeof deleteAction !== "undefined" && deleteAction) { %>
          <form
            action="<%= deleteAction %>"
            method="POST"
            data-confirm-action="<%= deleteLabel || 'Apagar publicação' %>?"
          >
            <button
              type="submit"
              class="sz-post-action sz-post-action-danger"
              title="<%= deleteLabel || 'Apagar' %>"
              aria-label="<%= deleteLabel || 'Apagar' %>"
            >
              🗑
            </button>
          </form>
        <% } %>

        <strong>#<%= postNumber %></strong>
      </div>
    </div>

    <div class="sz-post-content">
      <%- renderFormattedUserText(content) %>
    </div>

    <% if (author.signatureText || author.signatureImageUrl) { %>
      <div class="sz-post-signature">
        <span>Assinatura</span>

        <% if (author.signatureText) { %>
          <p><%- renderFormattedUserText(author.signatureText) %></p>
        <% } %>

        <% if (author.signatureImageUrl) { %>
          <img src="<%= author.signatureImageUrl %>" alt="Assinatura de <%= author.name %>">
        <% } %>
      </div>
    <% } %>

  </div>

</article>
