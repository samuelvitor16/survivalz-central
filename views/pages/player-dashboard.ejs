<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section">
      <div class="container">

        <% const gameStats = getGameStats(user); %>

        <section class="sz-dashboard-hero">

          <div class="sz-dashboard-profile">

            <a href="/perfil/<%= user.id %>" class="sz-dashboard-avatar">
              <% if (user.avatarUrl) { %>
                <img
                  src="<%= user.avatarUrl %>"
                  alt="Avatar de <%= user.name %>"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                >

                <span style="display:none;">
                  <%= user.name.charAt(0).toUpperCase() %>
                </span>
              <% } else { %>
                <span><%= user.name.charAt(0).toUpperCase() %></span>
              <% } %>
            </a>

            <div class="sz-dashboard-main-info">
              <span class="sz-dashboard-kicker">Meu painel</span>

              <h1>Bem-vindo, <%= user.name %></h1>

              <p>
                Gerencie seu perfil, acompanhe suas atividades, veja suas medalhas
                e acesse rapidamente as áreas principais da Central SurvivalZ.
              </p>

              <div class="sz-dashboard-rank sz-dashboard-rank-<%= user.role.toLowerCase() %>">
                <div class="sz-dashboard-rank-icon">
                  <% if (user.role === "OWNER") { %>
                    👑
                  <% } else if (user.role === "ADMIN") { %>
                    🛡️
                  <% } else if (user.role === "STAFF" || user.role === "MODERADOR") { %>
                    ⚔️
                  <% } else { %>
                    ☣
                  <% } %>
                </div>

                <div>
                  <span>Cargo</span>
                  <strong><%= roleDisplayLabel(user.role) %></strong>
                </div>
              </div>

              <div class="sz-dashboard-user-tags">
                <span>Nick: <strong><%= user.sampNick || "Não informado" %></strong></span>
                <span>Reputação: <strong><%= user.reputation || 0 %></strong></span>
                <span>Medalhas: <strong><%= user.medals ? user.medals.length : 0 %></strong></span>
              </div>
            </div>

          </div>

          <div class="sz-dashboard-side-actions">
            <a href="/perfil/<%= user.id %>">Meu perfil</a>
            <a href="/perfil/editar">Editar perfil</a>
            <a href="/sair" class="danger">Sair</a>
          </div>

        </section>

        <nav class="sz-dashboard-shortcuts">
          <a href="/comunidade">
            <span>🌐</span>
            Comunidade
          </a>

          <a href="/forum">
            <span>💬</span>
            Fórum
          </a>

          <a href="/forum/categoria/comunidade/novo">
            <span>✍️</span>
            Criar tópico
          </a>

          <a href="/forum/categoria/denuncias/novo">
            <span>⚠️</span>
            Criar denúncia
          </a>

          <a href="/loja">
            <span>🛒</span>
            Loja
          </a>
          <a href="/painel/pedidos">
            <span>$</span>
            Meus pedidos
          </a>
        </nav>

        <section class="sz-dashboard-game-card">
          <div class="sz-dashboard-section-header">
            <div>
              <span>Dados do servidor</span>
              <h2>Personagem SurvivalZ</h2>
            </div>

            <strong>Preparado para sync SA-MP</strong>
          </div>

          <div class="sz-dashboard-game-grid">
            <div>
              <span>ZCoins</span>
              <strong><%= gameStats.zCoins %></strong>
            </div>

            <div>
              <span>Nível</span>
              <strong><%= gameStats.level %></strong>
            </div>

            <div>
              <span>XP</span>
              <strong><%= gameStats.xp %></strong>
            </div>

            <div>
              <span>VIP</span>
              <strong><%= gameStats.vip %></strong>
            </div>

            <div>
              <span>Clã / Facção</span>
              <strong><%= gameStats.clan %></strong>
            </div>

            <div>
              <span>Kills</span>
              <strong><%= gameStats.kills %></strong>
            </div>

            <div>
              <span>Mortes</span>
              <strong><%= gameStats.deaths %></strong>
            </div>

            <div>
              <span>Tempo jogado</span>
              <strong><%= gameStats.playtime %></strong>
            </div>

            <div>
              <span>Último login</span>
              <strong><%= gameStats.lastGameLogin %></strong>
            </div>

            <div>
              <span>Status</span>
              <strong><%= gameStats.onlineStatus %></strong>
            </div>
          </div>
        </section>

        <section class="sz-dashboard-overview-grid">

          <article class="sz-dashboard-card">
            <div class="sz-dashboard-card-icon">☣</div>
            <span>Conta</span>
            <h2>Perfil</h2>

            <p>
              <strong>E-mail:</strong> <%= user.email %><br>
              <strong>Discord:</strong> <%= user.discord || "Não informado" %><br>
              <strong>Cargo:</strong> <%= roleDisplayLabel(user.role) %>
            </p>
          </article>

          <article class="sz-dashboard-card">
            <div class="sz-dashboard-card-icon">🏅</div>
            <span>Conquistas</span>
            <h2>Medalhas recentes</h2>

            <% if (!user.medals || user.medals.length === 0) { %>
              <p>Suas medalhas aparecerão aqui quando forem concedidas pela staff.</p>
            <% } else { %>
              <div class="sz-dashboard-medals">
                <% user.medals.slice(0, 8).forEach((userMedal) => { %>
                  <span
                    class="sz-dashboard-medal medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
                    title="<%= medalTooltip(userMedal) %>"
                    data-tooltip="<%= medalTooltip(userMedal) %>"
                  >
                    <%= userMedal.medal.icon || "🏅" %>
                  </span>
                <% }) %>
              </div>
            <% } %>
          </article>

          <article class="sz-dashboard-card">
            <div class="sz-dashboard-card-icon">▣</div>
            <span>Fórum</span>
            <h2>Tópicos</h2>

            <p>
              Você possui <strong><%= topics.length %></strong> tópico(s) público(s) recente(s).
            </p>

            <a href="/forum">Acessar fórum</a>
          </article>

          <article class="sz-dashboard-card">
            <div class="sz-dashboard-card-icon">!</div>
            <span>Central</span>
            <h2>Denúncias</h2>

            <p>
              Você possui <strong><%= reports.length %></strong> denúncia(s) recente(s).
            </p>

            <a href="/forum/categoria/denuncias">Ver denúncias</a>
          </article>

          <article class="sz-dashboard-card">
            <div class="sz-dashboard-card-icon">$</div>
            <span>Loja Beta</span>
            <h2>Meus pedidos</h2>

            <p>
              Voce possui <strong><%= orderStats.total %></strong> pedido(s) vinculado(s) a sua conta.
              <% if (recentOrders.length > 0) { %>
                Ultimo pedido: <strong><%= recentOrders[0].code %></strong>.
              <% } %>
            </p>

            <a href="/painel/pedidos">Ver pedidos</a>
          </article>

        </section>

        <section class="sz-dashboard-content-grid">

          <div class="sz-dashboard-list-card">
            <div class="sz-dashboard-section-header">
              <div>
                <span>Fórum</span>
                <h2>Tópicos recentes</h2>
              </div>

              <a href="/forum/categoria/comunidade/novo">Criar tópico</a>
            </div>

            <% if (topics.length === 0) { %>
              <p class="player-empty-text">Você ainda não criou tópicos públicos.</p>
            <% } %>

            <div class="sz-dashboard-list">
              <% topics.forEach((topic) => { %>
                <a href="/forum/topico/<%= topic.id %>" class="sz-dashboard-list-item">
                  <div>
                    <strong><%= topic.title %></strong>
                    <span><%= topic.category.name %> • <%= topic._count.posts %> resposta(s)</span>
                  </div>

                  <small><%= topicStatusLabel(topic.status) %></small>
                </a>
              <% }) %>
            </div>
          </div>

          <div class="sz-dashboard-list-card">
            <div class="sz-dashboard-section-header">
              <div>
                <span>Denúncias</span>
                <h2>Denúncias recentes</h2>
              </div>

              <a href="/forum/categoria/denuncias/novo">Criar denúncia</a>
            </div>

            <% if (reports.length === 0) { %>
              <p class="player-empty-text">Você ainda não abriu nenhuma denúncia.</p>
            <% } %>

            <div class="sz-dashboard-list">
              <% reports.forEach((report) => { %>
                <a href="/forum/topico/<%= report.id %>" class="sz-dashboard-list-item">
                  <div>
                    <strong><%= report.title %></strong>
                    <span>Acusado: <%= report.reportAccusedNick || "Não informado" %></span>
                  </div>

                  <small><%= topicStatusLabel(report.status) %></small>
                </a>
              <% }) %>
            </div>
          </div>

          <div class="sz-dashboard-list-card sz-dashboard-wide">
            <div class="sz-dashboard-section-header">
              <div>
                <span>Atividade</span>
                <h2>Respostas recentes</h2>
              </div>

              <strong><%= repliesCount %> resposta(s)</strong>
            </div>

            <% if (recentReplies.length === 0) { %>
              <p class="player-empty-text">Você ainda não respondeu tópicos do fórum.</p>
            <% } %>

            <div class="sz-dashboard-list">
              <% recentReplies.forEach((reply) => { %>
                <a href="/forum/topico/<%= reply.topic.id %>" class="sz-dashboard-list-item">
                  <div>
                    <strong><%= reply.topic.title %></strong>
                    <span><%= reply.topic.category.name %> • respondido em <%= formatDate(reply.createdAt) %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>

        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
