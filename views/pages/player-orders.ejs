<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section">
      <div class="container">

        <div class="player-dashboard-header sz-player-orders-header">
          <div>
            <span class="section-tag">Loja Beta</span>
            <h1>Meus pedidos</h1>
            <p>Acompanhe seus pedidos vinculados a sua conta SurvivalZ.</p>
          </div>

          <a href="/painel" class="btn-secondary">Voltar ao painel</a>
        </div>

        <% if (orders.length === 0) { %>
          <section class="sz-player-orders-empty">
            <strong>Nenhum pedido vinculado ainda.</strong>
            <p>Pedidos feitos enquanto voce estiver logado aparecerao aqui automaticamente.</p>
            <a href="/loja" class="btn-primary">Abrir Loja Beta</a>
          </section>
        <% } else { %>
          <section class="sz-player-orders-grid">
            <% orders.forEach((order) => { %>
              <article class="sz-player-order-card">
                <div class="sz-player-order-top">
                  <div>
                    <span>Pedido</span>
                    <h2><%= order.code %></h2>
                    <small><%= new Date(order.createdAt).toLocaleString("pt-BR") %></small>
                  </div>

                  <strong class="sz-player-order-status status-<%= String(order.status || 'pendente').toLowerCase() %>">
                    <%= String(order.status || "pendente").replace(/_/g, " ") %>
                  </strong>
                </div>

                <div class="sz-player-order-items">
                  <% order.items.forEach((item) => { %>
                    <div>
                      <strong><%= item.quantity %>x <%= item.name %></strong>
                      <span><%= formatPrice(item.totalCents) %></span>
                    </div>
                  <% }) %>
                </div>

                <div class="sz-player-order-meta">
                  <div>
                    <span>Total</span>
                    <strong><%= formatPrice(order.total) %></strong>
                  </div>

                  <div>
                    <span>Cupom</span>
                    <strong><%= order.coupon || "Nenhum" %></strong>
                  </div>

                  <div>
                    <span>Pagamento</span>
                    <strong><%= order.paymentMethod === "pix" || !order.paymentMethod ? "Pix manual" : order.paymentMethod %></strong>
                  </div>
                </div>

                <a href="/painel/pedidos/<%= order.id %>" class="sz-player-order-btn">Ver detalhes</a>
              </article>
            <% }) %>
          </section>
        <% } %>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
