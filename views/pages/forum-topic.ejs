<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/forum.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="forum-section">
      <div class="container">

        <div class="forum-topic-page-header">
          <a href="/forum/categoria/<%= topic.category.slug %>" class="forum-back-link">
            Voltar para <%= topic.category.name %>
          </a>

          <span class="section-tag"><%= topic.category.icon || "☣" %> <%= topic.category.name %></span>

          <span class="forum-topic-status status-<%= topic.status.toLowerCase() %>">
            <%= topicStatusLabel(topic.status) %>
          </span>

          <h1><%= topic.title %></h1>

          <p>
            Criado por <a href="/perfil/<%= topic.author.id %>"><strong><%= topic.author.name %></strong></a>
            • <%= formatDate(topic.createdAt) %>
            • <%= topic.views + 1 %> visualizacoes
          </p>

          <% if (["STAFF", "ADMIN", "OWNER"].includes(playerRole)) { %>
            <div class="forum-topic-staff-actions">
              <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                <input type="hidden" name="status" value="OPEN">
                <button type="submit" class="<%= topic.status === 'OPEN' ? 'active' : '' %>">Abrir</button>
              </form>

              <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                <input type="hidden" name="status" value="CLOSED">
                <button type="submit" class="<%= topic.status === 'CLOSED' ? 'active' : '' %>">Fechar</button>
              </form>

              <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                <input type="hidden" name="status" value="PINNED">
                <button type="submit" class="<%= topic.status === 'PINNED' ? 'active' : '' %>">Fixar</button>
              </form>

              <form action="/forum/topico/<%= topic.id %>/status" method="POST">
                <input type="hidden" name="status" value="ARCHIVED">
                <button type="submit" class="<%= topic.status === 'ARCHIVED' ? 'active' : '' %>">Arquivar</button>
              </form>
            </div>
          <% } %>
        </div>

        <% if (topic.category.slug === "denuncias") { %>
          <div class="forum-report-summary">
            <h2>Detalhes da denuncia</h2>

            <div class="forum-report-grid">
              <div>
                <span>Acusado</span>
                <strong><%= topic.reportAccusedNick || "Nao informado" %></strong>
              </div>

              <div>
                <span>Motivo</span>
                <strong><%= topic.reportReason || "Nao informado" %></strong>
              </div>
            </div>

            <div class="forum-report-evidence">
              <span>Provas</span>
              <p><%- renderUserText(topic.reportEvidence || "Nenhuma prova informada.") %></p>
            </div>
          </div>
        <% } %>

        <%- include("../partials/forum-post-card", {
          author: topic.author,
          content: topic.content,
          postedAt: topic.createdAt,
          postNumber: 1,
          dateLabel: "Postado em"
        }) %>

        <% topic.posts.forEach((post, index) => { %>
          <%- include("../partials/forum-post-card", {
            author: post.author,
            content: post.content,
            postedAt: post.createdAt,
            postNumber: index + 2,
            dateLabel: "Respondido em",
            isReply: true
          }) %>
        <% }) %>

        <div class="forum-reply-form-card">
          <% if (replyError) { %>
            <div class="forum-permission-alert">
              <strong>Topico fechado</strong>
              <span><%= replyError %></span>
            </div>
          <% } %>

          <% if (topic.status === "CLOSED" || topic.status === "ARCHIVED") { %>
            <h2>Respostas bloqueadas</h2>
            <p>Este topico esta fechado ou arquivado e nao aceita novas respostas.</p>
          <% } else if (isPlayerLogged) { %>
            <h2>Responder topico</h2>

            <form action="/forum/topico/<%= topic.id %>/responder" method="POST" class="forum-form">
              <div class="form-group">
                <label for="content">Sua resposta</label>
                <textarea id="content" name="content" placeholder="Escreva sua resposta..." required></textarea>
              </div>

              <button type="submit" class="btn-primary forum-submit-btn">
                Enviar resposta
              </button>
            </form>
          <% } else { %>
            <h2>Entre para responder</h2>
            <p>Voce precisa estar logado para participar deste topico.</p>
            <a href="/entrar" class="btn-primary">Entrar na conta</a>
          <% } %>
        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
