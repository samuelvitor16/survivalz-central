<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section">
      <div class="container">

        <div class="player-dashboard-header">
          <div>
            <span class="section-tag">Meu painel</span>

            <h1>Bem-vindo, <%= user ? user.name : "sobrevivente" %></h1>

            <p>
              Acompanhe sua conta, seus tópicos, denúncias, respostas e atalhos
              principais da Central SurvivalZ.
            </p>
          </div>

          <a href="/sair" class="btn-secondary">
            Sair da conta
          </a>
        </div>

        <div class="player-dashboard-grid">
          <div class="player-panel-card">
            <span>👤</span>
            <h2>Minha conta</h2>
            <p>
              <strong>E-mail:</strong> <%= user.email %><br>
              <strong>Discord:</strong> <%= user.discord || "Não informado" %><br>
              <strong>Nick:</strong> <%= user.sampNick || "Não informado" %><br>
              <strong>Cargo:</strong> <%= user.role %>
            </p>
          </div>

          <div class="player-panel-card">
            <span>💬</span>
            <h2>Meus tópicos</h2>
            <p>
              Você criou <strong><%= topics.length %></strong> tópico(s) recente(s).
            </p>

            <a href="/forum">Acessar fórum</a>
          </div>

          <div class="player-panel-card">
            <span>⚠</span>
            <h2>Minhas denúncias</h2>
            <p>
              Você possui <strong><%= reports.length %></strong> denúncia(s) recente(s).
            </p>

            <a href="/forum/categoria/denuncias">Ver denúncias</a>
          </div>

          <div class="player-panel-card">
            <span>✍️</span>
            <h2>Minhas respostas</h2>
            <p>
              Você enviou <strong><%= repliesCount %></strong> resposta(s) no fórum.
            </p>
          </div>
        </div>

        <div class="player-dashboard-content-grid">
          <div class="player-dashboard-list-card">
            <div class="player-list-header">
              <h2>Últimos tópicos</h2>
              <a href="/forum">Ver fórum</a>
            </div>

            <% if (topics.length === 0) { %>
              <p class="player-empty-text">
                Você ainda não criou nenhum tópico.
              </p>
            <% } %>

            <% topics.forEach((topic) => { %>
              <a href="/forum/topico/<%= topic.id %>" class="player-dashboard-topic-item">
                <div>
                  <strong><%= topic.title %></strong>
                  <span>
                    <%= topic.category.name %> • <%= topic._count.posts %> resposta(s)
                  </span>
                </div>

                <small><%= topic.status %></small>
              </a>
            <% }) %>
          </div>

          <div class="player-dashboard-list-card">
            <div class="player-list-header">
              <h2>Minhas denúncias</h2>
              <a href="/forum/categoria/denuncias">Ver área</a>
            </div>

            <% if (reports.length === 0) { %>
              <p class="player-empty-text">
                Você ainda não abriu nenhuma denúncia.
              </p>
            <% } %>

            <% reports.forEach((report) => { %>
              <a href="/forum/topico/<%= report.id %>" class="player-dashboard-topic-item">
                <div>
                  <strong><%= report.title %></strong>
                  <span>
                    Acusado: <%= report.reportAccusedNick || "Não informado" %>
                  </span>
                </div>

                <small><%= report.status %></small>
              </a>
            <% }) %>
          </div>
        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>