<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/player.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="player-dashboard-section">
      <div class="container">

        <% const profileBannerUrl = user.bannerUrl || "/images/home/hero-bg.png"; %>

        <section class="sz-profile">

          <div
            class="sz-profile-cover"
            style='background-image: linear-gradient(90deg, rgba(0,0,0,.78), rgba(120,0,0,.30)), url("<%= profileBannerUrl %>");'
          ></div>

          <div class="sz-profile-main">

            <div class="sz-profile-avatar-wrap">
              <% if (user.avatarUrl) { %>
                <img
                  src="<%= user.avatarUrl %>"
                  alt="Avatar de <%= user.name %>"
                  class="sz-profile-avatar"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                >

                <div class="sz-profile-avatar-fallback" style="display:none;">
                  <%= user.name.charAt(0).toUpperCase() %>
                </div>
              <% } else { %>
                <div class="sz-profile-avatar-fallback">
                  <%= user.name.charAt(0).toUpperCase() %>
                </div>
              <% } %>
            </div>

            <div class="sz-profile-info">

              <span class="sz-profile-kicker">Perfil SurvivalZ</span>

              <div class="sz-profile-title-row">
                <div>
                  <h1><%= user.name %></h1>

                  <div class="sz-profile-subline">
                    <span><%= user.sampNick || "Nick não informado" %></span>

                    <% if (user.location) { %>
                      <span><%= user.location %></span>
                    <% } %>
                  </div>
                </div>

                <div class="sz-profile-actions">
                  <% if (isOwnProfile) { %>
                    <a href="/perfil/editar">Editar perfil</a>
                  <% } %>

                  <a href="/forum">Ver fórum</a>
                  <a href="/comunidade">Comunidade</a>
                </div>
              </div>

              <div class="sz-profile-rank sz-profile-rank-<%= user.role.toLowerCase() %>">
                <div class="sz-profile-rank-icon">
                  <% if (user.role === "OWNER") { %>
                    👑
                  <% } else if (user.role === "ADMIN") { %>
                    🛡️
                  <% } else if (user.role === "STAFF" || user.role === "MODERADOR") { %>
                    ⚔️
                  <% } else { %>
                    ☣
                  <% } %>
                </div>

                <div class="sz-profile-rank-text">
                  <span>Cargo</span>
                  <strong><%= roleDisplayLabel(user.role) %></strong>
                </div>
              </div>

              <% if (user.medals && user.medals.length > 0) { %>
                <div class="sz-profile-insignias">
                  <span class="sz-profile-box-title">Insígnias recentes</span>

                  <div class="sz-profile-insignia-list">
                    <% user.medals.slice(0, 8).forEach((userMedal) => { %>
                      <span
                        class="sz-profile-insignia medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
                        title="<%= medalTooltip(userMedal) %>"
                        data-tooltip="<%= medalTooltip(userMedal) %>"
                      >
                        <%= userMedal.medal.icon || "🏅" %>
                      </span>
                    <% }) %>
                  </div>
                </div>
              <% } %>

              <div class="sz-profile-bio">
                <% if (user.bio) { %>
                  <%- renderUserText(user.bio) %>
                <% } else { %>
                  Este sobrevivente ainda não adicionou uma bio.
                <% } %>
              </div>

            </div>
          </div>

          <div class="sz-profile-stats">
            <div>
              <span>Tópicos</span>
              <strong><%= publicTopicsCount %></strong>
            </div>

            <div>
              <span>Respostas</span>
              <strong><%= user._count.posts %></strong>
            </div>

            <div>
              <span>Medalhas</span>
              <strong><%= user.medals.length %></strong>
            </div>

            <div>
              <span>Reputação</span>
              <strong><%= user.reputation || 0 %></strong>
            </div>

            <div>
              <span>Registro</span>
              <strong><%= formatDate(user.createdAt) %></strong>
            </div>
          </div>

          <nav class="sz-profile-tabs">
            <a class="<%= activeTab === 'posts' ? 'active' : '' %>" href="/perfil/<%= user.id %>?tab=posts">Postagens</a>
            <a class="<%= activeTab === 'atividade' ? 'active' : '' %>" href="/perfil/<%= user.id %>?tab=atividade">Última atividade</a>
            <a class="<%= activeTab === 'sobre' ? 'active' : '' %>" href="/perfil/<%= user.id %>?tab=sobre">Sobre</a>
            <a class="<%= activeTab === 'medalhas' ? 'active' : '' %>" href="/perfil/<%= user.id %>?tab=medalhas">Medalhas</a>
          </nav>

        </section>

        <section class="sz-profile-panel">

          <% if (activeTab === "posts") { %>
            <div class="sz-profile-panel-header">
              <div>
                <span>Atividade pública</span>
                <h2>Postagens</h2>
              </div>

              <a href="/forum">Ver fórum</a>
            </div>

            <% if (user.topics.length === 0) { %>
              <p class="player-empty-text">Este jogador ainda não criou tópicos públicos.</p>
            <% } %>

            <div class="sz-profile-list">
              <% user.topics.forEach((topic) => { %>
                <a href="/forum/topico/<%= topic.id %>" class="sz-profile-list-item">
                  <div>
                    <strong><%= topic.title %></strong>
                    <span>
                      <%= topic.category.name %> • <%= topic._count.posts %> resposta(s)
                    </span>
                  </div>

                  <small><%= topicStatusLabel(topic.status) %></small>
                </a>
              <% }) %>
            </div>
          <% } %>

          <% if (activeTab === "sobre") { %>
            <div class="sz-profile-panel-header">
              <div>
                <span>Informações públicas</span>
                <h2>Sobre</h2>
              </div>
            </div>

            <div class="sz-profile-about-grid">
              <div><span>Nome público</span><strong><%= user.name %></strong></div>
              <div><span>Nick no servidor</span><strong><%= user.sampNick || "Não informado" %></strong></div>
              <div><span>Discord</span><strong><%= user.discord || "Não informado" %></strong></div>
              <div><span>Localização / grupo</span><strong><%= user.location || "Não informado" %></strong></div>
              <div><span>Cargo</span><strong><%= roleDisplayLabel(user.role) %></strong></div>
              <div><span>Conta criada em</span><strong><%= formatDate(user.createdAt) %></strong></div>
              <div><span>Reputação</span><strong><%= user.reputation || 0 %></strong></div>
              <div><span>Medalhas</span><strong><%= user.medals.length %></strong></div>
            </div>

            <div class="sz-profile-about-bio">
              <h3>Bio</h3>

              <% if (user.bio) { %>
                <p><%- renderUserText(user.bio) %></p>
              <% } else { %>
                <p>Nenhuma bio publicada.</p>
              <% } %>
            </div>
          <% } %>

          <% if (activeTab === "medalhas") { %>
            <div class="sz-profile-panel-header">
              <div>
                <span>Conquistas da comunidade</span>
                <h2>Medalhas</h2>
              </div>
            </div>

            <% if (user.medals.length === 0) { %>
              <p class="player-empty-text">Este jogador ainda não possui medalhas.</p>
            <% } %>

            <div class="sz-profile-medals-grid">
              <% user.medals.forEach((userMedal) => { %>
                <article class="sz-profile-medal-card medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>">
                  <div class="sz-profile-medal-icon">
                    <span><%= userMedal.medal.icon || "🏅" %></span>
                  </div>

                  <div>
                    <strong><%= userMedal.medal.name %></strong>
                    <span><%= medalRarityLabel(userMedal.medal.rarity) %></span>
                    <p><%= userMedal.medal.description || "Medalha SurvivalZ." %></p>

                    <% if (userMedal.reason) { %>
                      <small>Motivo: <%= userMedal.reason %></small>
                    <% } %>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>

          <% if (activeTab === "atividade") { %>
            <div class="sz-profile-panel-header">
              <div>
                <span>Movimentação pública</span>
                <h2>Última atividade</h2>
              </div>

              <a href="/forum">Ver fórum</a>
            </div>

            <% if (recentPosts.length === 0 && user.topics.length === 0) { %>
              <p class="player-empty-text">A atividade pública deste jogador aparecerá aqui.</p>
            <% } %>

            <div class="sz-profile-list">
              <% user.topics.slice(0, 5).forEach((topic) => { %>
                <a href="/forum/topico/<%= topic.id %>" class="sz-profile-list-item">
                  <div>
                    <strong>Criou: <%= topic.title %></strong>
                    <span><%= topic.category.name %> • <%= formatDate(topic.createdAt) %></span>
                  </div>
                </a>
              <% }) %>

              <% recentPosts.forEach((post) => { %>
                <a href="/forum/topico/<%= post.topic.id %>" class="sz-profile-list-item">
                  <div>
                    <strong>Respondeu em: <%= post.topic.title %></strong>
                    <span><%= post.topic.category.name %> • <%= formatDate(post.createdAt) %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } %>

        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
