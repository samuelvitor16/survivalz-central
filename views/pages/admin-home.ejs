<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/admin.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="admin-home-section">
      <div class="container">

        <div class="admin-home-header">
          <div>
            <span class="section-tag">Painel administrativo</span>

            <h1>Central Admin SurvivalZ</h1>

            <p>
              Área reservada para gestão principal do servidor. Aqui serão controlados
              usuários, permissões, denúncias, loja, compras, logs e configurações
              importantes da Central SurvivalZ.
            </p>
          </div>

          <div class="admin-access-card">
            <span>Nível de acesso</span>
            <strong>Administrador</strong>
          </div>
        </div>

       <section class="admin-overview-grid">
  <div class="admin-overview-card">
    <span>Total de pedidos</span>
    <strong><%= totalOrders %></strong>
    <p>Pedidos enviados pela Loja Beta.</p>
  </div>

  <div class="admin-overview-card">
    <span>Pedidos pendentes</span>
    <strong><%= pendingOrders %></strong>
    <p>Aguardando análise da gestão.</p>
  </div>

  <div class="admin-overview-card">
    <span>Pedidos pagos</span>
    <strong><%= paidOrders %></strong>
    <p>Pedidos marcados como pagos.</p>
  </div>

  <div class="admin-overview-card">
    <span>Pedidos entregues</span>
    <strong><%= deliveredOrders %></strong>
    <p>Pedidos já liberados manualmente.</p>
  </div>
</section>

        <section class="admin-panel-grid">

          <a href="#" class="admin-panel-card disabled">
            <div class="admin-panel-icon">👥</div>

            <div>
              <h2>Usuários</h2>
              <p>
                Gerenciar contas, cargos, permissões e status dos usuários cadastrados
                na Central SurvivalZ.
              </p>
            </div>
          </a>

          <a href="/staff/denuncias" class="admin-panel-card">
            <div class="admin-panel-icon">⚠</div>

            <div>
              <h2>Denúncias</h2>
              <p>
                Acompanhar todas as denúncias abertas, em análise, recusadas e fechadas
                pela equipe.
              </p>
            </div>
          </a>

          <a href="#" class="admin-panel-card disabled">
            <div class="admin-panel-icon">🛒</div>

            <div>
              <h2>Loja</h2>
              <p>
                Criar produtos, editar valores, controlar disponibilidade e preparar
                a futura entrega automática no servidor.
              </p>
            </div>
          </a>

          <a href="/admin/pedidos" class="admin-panel-card">
        <div class="admin-panel-icon">💳</div>

        <div>
          <h2>Pedidos da Loja</h2>
          <p>
            Ver pedidos enviados pelos jogadores, conferir carrinho, cupom aplicado,
            dados do comprador e alterar status de pagamento/entrega.
          </p>
        </div>
      </a>

          <a href="#" class="admin-panel-card disabled">
            <div class="admin-panel-icon">📋</div>

            <div>
              <h2>Logs</h2>
              <p>
                Consultar ações importantes feitas por staff, administradores e pelo
                próprio sistema.
              </p>
            </div>
          </a>

          <a href="#" class="admin-panel-card disabled">
            <div class="admin-panel-icon">⚙</div>

            <div>
              <h2>Configurações</h2>
              <p>
                Ajustar informações internas, permissões, integrações e opções avançadas
                da central.
              </p>
            </div>
          </a>

        </section>

        <section class="admin-content-grid">

          <div class="admin-box">
            <div class="admin-box-header">
              <h2>Resumo da gestão</h2>
              <span>Prévia visual</span>
            </div>

            <div class="admin-summary-list">
              <div class="admin-summary-item">
                <strong>Servidor</strong>
                <span>Em desenvolvimento</span>
              </div>

              <div class="admin-summary-item">
                <strong>Integração SAMP</strong>
                <span>Planejada</span>
              </div>

              <div class="admin-summary-item">
                <strong>Loja automática</strong>
                <span>Fase futura</span>
              </div>

              <div class="admin-summary-item">
                <strong>Sistema de denúncias</strong>
                <span>Visual pronto</span>
              </div>
            </div>
          </div>

          <div class="admin-box">
            <div class="admin-box-header">
              <h2>Atividade administrativa</h2>
              <span>Logs futuros</span>
            </div>

            <div class="admin-activity-list">
              <div class="admin-activity-item">
                <span class="activity-dot"></span>

                <div>
                  <strong>Painel Admin criado</strong>
                  <p>Estrutura visual inicial da gestão foi adicionada.</p>
                </div>
              </div>

              <div class="admin-activity-item">
                <span class="activity-dot"></span>

                <div>
                  <strong>Denúncias conectadas ao painel</strong>
                  <p>Administradores poderão acompanhar casos pela central.</p>
                </div>
              </div>

              <div class="admin-activity-item">
                <span class="activity-dot"></span>

                <div>
                  <strong>Loja marcada como fase futura</strong>
                  <p>Área será criada após login, banco de dados e permissões.</p>
                </div>
              </div>
            </div>
          </div>

        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>