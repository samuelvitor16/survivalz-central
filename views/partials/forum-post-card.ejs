<article class="sz-post <%= typeof isReply !== 'undefined' && isReply ? 'sz-post-reply' : '' %>">

  <aside class="sz-author-panel">

    <a href="/perfil/<%= author.id %>" class="sz-author-avatar">
      <% if (author.avatarUrl) { %>
        <img
          src="<%= author.avatarUrl %>"
          alt="Avatar de <%= displayUserName(author) %>"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        >

        <div class="sz-author-avatar-fallback" style="display:none;">
          <%= displayInitial(author) %>
        </div>
      <% } else { %>
        <div class="sz-author-avatar-fallback">
          <%= displayInitial(author) %>
        </div>
      <% } %>
    </a>

    <div class="sz-author-name">
      <%= displayUserName(author) %>
    </div>

    <%
      var postCardAuthorRole = roleClass(author.role);

      var postCardRankMeta = {
        desenvolvedor: {
          icon: "💻",
          level: "5000",
          tier: "NÚCLEO",
          className: "rank-core"
        },
        diretor: {
          icon: "👑",
          level: "2002",
          tier: "DIREÇÃO",
          className: "rank-director"
        },
        sub_diretor: {
          icon: "⭐",
          level: "2001",
          tier: "DIREÇÃO",
          className: "rank-subdirector"
        },
        gerente: {
          icon: "💼",
          level: "2000",
          tier: "GESTÃO",
          className: "rank-manager"
        },
        coordenador: {
          icon: "📌",
          level: "006",
          tier: "OPERAÇÃO",
          className: "rank-coordinator"
        },
        supervisor: {
          icon: "👁",
          level: "005",
          tier: "OPERAÇÃO",
          className: "rank-supervisor"
        },
        administrador: {
          icon: "🛡️",
          level: "004",
          tier: "STAFF",
          className: "rank-admin"
        },
        moderador: {
          icon: "⚔️",
          level: "003",
          tier: "STAFF",
          className: "rank-mod"
        },
        estagiario: {
          icon: "🧪",
          level: "002",
          tier: "STAFF",
          className: "rank-trainee"
        },
        suporte: {
          icon: "🎧",
          level: "001",
          tier: "SUPORTE",
          className: "rank-support"
        },
        sobrevivente: {
          icon: "☣",
          level: "000",
          tier: "SOBREVIVENTE",
          className: "rank-player"
        },
        premium: {
          icon: "💎",
          level: "010",
          tier: "PREMIUM",
          className: "rank-premium"
        },
        beta_tester: {
          icon: "🧪",
          level: "020",
          tier: "BETA",
          className: "rank-beta"
        },
        youtuber: {
          icon: "▶️",
          level: "030",
          tier: "CRIADOR",
          className: "rank-youtuber"
        },

        owner: {
          icon: "💻",
          level: "5000",
          tier: "NÚCLEO",
          className: "rank-core"
        },
        admin: {
          icon: "🛡️",
          level: "004",
          tier: "STAFF",
          className: "rank-admin"
        },
        staff: {
          icon: "🎧",
          level: "001",
          tier: "SUPORTE",
          className: "rank-support"
        }
      };

      var postCardCurrentRank = postCardRankMeta[postCardAuthorRole] || postCardRankMeta.sobrevivente;
    %>

    <div class="sz-author-rank-v3 sz-author-rank-<%= postCardAuthorRole %> <%= postCardCurrentRank.className %>">
      <div class="sz-rank-topline">
        <span><%= postCardCurrentRank.tier %></span>
        <strong>NV <%= postCardCurrentRank.level %></strong>
      </div>

      <div class="sz-rank-main">
        <div class="sz-rank-emblem">
          <span><%= postCardCurrentRank.icon %></span>
        </div>

        <div class="sz-rank-info">
          <small>Cargo SurvivalZ</small>
          <strong><%= roleDisplayLabel(author.role) %></strong>
        </div>
      </div>

      <div class="sz-rank-authority">
        <span>Autoridade</span>
        <div>
          <i></i>
          <i></i>
          <i></i>
          <i></i>
          <i></i>
        </div>
      </div>
    </div>

    <% if (author.medals && author.medals.length > 0) { %>
      <div class="sz-author-insignias">
        <span class="sz-author-box-title">Insígnias</span>

        <div class="sz-author-insignia-list">
          <% author.medals.slice(0, 6).forEach((userMedal) => { %>
            <span
              class="sz-author-insignia medal-rarity-<%= userMedal.medal.rarity.toLowerCase() %>"
              title="<%= medalTooltip(userMedal) %>"
              data-tooltip="<%= medalTooltip(userMedal) %>"
            >
              <%= userMedal.medal.icon || "🏅" %>
            </span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="sz-author-info-list">
      <div class="sz-author-info-row">
        <span>Nick</span>
        <strong><%= author.sampNick || "Não informado" %></strong>
      </div>

      <div class="sz-author-info-row">
        <span>Reputação</span>
        <strong><%= author.reputation || 0 %></strong>
      </div>

      <div class="sz-author-info-row">
        <span>Registro</span>
        <strong><%= formatDate(author.createdAt) %></strong>
      </div>
    </div>

    <div class="sz-author-stats">
      <div>
        <span>Tópicos</span>
        <strong><%= author._count ? author._count.topics : 0 %></strong>
      </div>

      <div>
        <span>Respostas</span>
        <strong><%= author._count ? author._count.posts : 0 %></strong>
      </div>
    </div>

    <a href="/perfil/<%= author.id %>" class="sz-author-profile-link">
      Ver perfil
    </a>

  </aside>

  <div class="sz-post-main">

    <div class="sz-post-top">
      <span><%= dateLabel %> <%= formatDate(postedAt) %></span>

      <div class="sz-post-actions">
        <% if (typeof editHref !== "undefined" && editHref) { %>
          <a
            href="<%= editHref %>"
            class="sz-post-action"
            title="Editar"
            aria-label="Editar publicação"
          >
            ✎
          </a>
        <% } %>

        <% if (typeof deleteAction !== "undefined" && deleteAction) { %>
          <form
            action="<%= deleteAction %>"
            method="POST"
            data-confirm-action="<%= deleteLabel || 'Apagar publicação' %>?"
          >
            <button
              type="submit"
              class="sz-post-action sz-post-action-danger"
              title="<%= deleteLabel || 'Apagar' %>"
              aria-label="<%= deleteLabel || 'Apagar' %>"
            >
              🗑
            </button>
          </form>
        <% } %>

        <strong>#<%= postNumber %></strong>
      </div>
    </div>

    <div class="sz-post-content">
      <%- renderFormattedUserText(content) %>
    </div>

    <% if (author.signatureText || author.signatureImageUrl) { %>
      <div class="sz-post-signature">
        <span>Assinatura</span>

        <% if (author.signatureText) { %>
          <p><%- renderFormattedUserText(author.signatureText) %></p>
        <% } %>

        <% if (author.signatureImageUrl) { %>
          <img src="<%= author.signatureImageUrl %>" alt="Assinatura de <%= displayUserName(author) %>">
        <% } %>
      </div>
    <% } %>

  </div>

</article>
