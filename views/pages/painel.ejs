<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/painel.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="dashboard-section">
      <div class="container">

        <div class="dashboard-header">
          <div>
            <span class="section-tag">Área do jogador</span>
            <h1>Painel do Sobrevivente</h1>
            <p>
              Acompanhe suas informações, status da conta, denúncias e futuros recursos
              integrados ao servidor SurvivalZ.
            </p>
          </div>

          <div class="player-status-card">
            <span>Status da conta</span>
            <strong>Sobrevivente</strong>
          </div>
        </div>

        <section class="profile-card">
          <div class="profile-avatar">D</div>

          <div class="profile-info">
            <h2>Dybala</h2>
            <p>Nick no servidor: <strong>Dybala_Survivor</strong></p>
            <span>Conta criada para testes da Central SurvivalZ</span>
          </div>
        </section>

        <section class="dashboard-grid">
          <div class="dashboard-card">
            <span class="card-label">Level</span>
            <strong>1</strong>
            <p>Progressão inicial do sobrevivente.</p>
          </div>

          <div class="dashboard-card">
            <span class="card-label">ZCoins</span>
            <strong>0</strong>
            <p>Moeda premium futura do servidor.</p>
          </div>

          <div class="dashboard-card">
            <span class="card-label">VIP</span>
            <strong>Nenhum</strong>
            <p>Status VIP vinculado à conta.</p>
          </div>

          <div class="dashboard-card">
            <span class="card-label">Denúncias abertas</span>
            <strong>0</strong>
            <p>Casos ativos criados por você.</p>
          </div>
        </section>

        <section class="dashboard-content">
          <div class="panel-box">
            <div class="panel-box-header">
              <h2>Últimas atividades</h2>
              <span>Em desenvolvimento</span>
            </div>

            <div class="empty-state">
              <h3>Nenhuma atividade registrada ainda</h3>
              <p>
                Futuramente, esta área exibirá login recente, compras, denúncias,
                punições, alterações de conta e eventos importantes.
              </p>
            </div>
          </div>

          <div class="panel-box">
            <div class="panel-box-header">
              <h2>Ações rápidas</h2>
              <span>Central</span>
            </div>

            <div class="quick-actions">
              <a href="#" class="quick-action">
                <strong>⚠ Abrir denúncia</strong>
                <span>Relate problemas com jogadores.</span>
              </a>

              <a href="#" class="quick-action">
                <strong>📖 Ver guia</strong>
                <span>Acesse regras e tutoriais.</span>
              </a>

              <a href="#" class="quick-action">
                <strong>🛒 Loja</strong>
                <span>Área planejada para compras futuras.</span>
              </a>
            </div>
          </div>
        </section>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>
