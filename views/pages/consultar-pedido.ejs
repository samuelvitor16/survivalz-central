<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/shop.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main>
    <section class="consult-order-section">
      <div class="container consult-order-container">

        <div class="consult-order-header">
          <span class="section-tag">Consultar pedido</span>

          <h1>Acompanhe sua compra</h1>

          <p>
            Digite o código do pedido e o e-mail ou Discord usado na compra para
            acompanhar o status da análise, pagamento e entrega.
          </p>
        </div>

        <div class="consult-order-grid">

          <div class="consult-order-card">
            <h2>Buscar pedido</h2>

            <% if (error) { %>
              <div class="consult-error">
                <%= error %>
              </div>
            <% } %>

            <form action="/loja/consultar" method="POST" class="consult-order-form">
              <div class="form-group">
                <label for="code">Código do pedido</label>
                <input
                  type="text"
                  id="code"
                  name="code"
                  placeholder="Ex: SZ-0001"
                  autocomplete="off"
                >
              </div>

              <div class="form-group">
                <label for="identifier">E-mail ou Discord</label>
                <input
                  type="text"
                  id="identifier"
                  name="identifier"
                  placeholder="Digite o e-mail ou Discord usado na compra"
                  autocomplete="off"
                >
              </div>

              <button type="submit" class="btn-primary consult-submit-btn">
                Consultar pedido
              </button>
            </form>

            <p class="consult-help-text">
              Não encontrou seu pedido? Entre em contato com a gestão pelo Discord
              e informe o código recebido após a compra.
            </p>
          </div>

          <div class="consult-order-card">
            <h2>Status do pedido</h2>

            <% if (!order) { %>
              <div class="consult-empty">
                <h3>Nenhum pedido carregado</h3>
                <p>
                  Após consultar, os detalhes do pedido aparecerão aqui.
                </p>
              </div>
            <% } else { %>

              <div class="consult-result-header">
                <span>Pedido</span>
                <strong><%= order.code %></strong>
              </div>

              <div class="consult-status-list">
                <div>
                  <span>Status geral</span>
                  <strong>
                    <%= String(order.status || "pendente").replace(/_/g, " ") %>
                  </strong>
                </div>

                <div>
                  <span>Pagamento</span>
                  <strong>
                    <%= String(order.paymentStatus || "aguardando pagamento").replace(/_/g, " ") %>
                  </strong>
                </div>

                <div>
                  <span>Entrega</span>
                  <strong>
                    <%= String(order.deliveryStatus || "pendente").replace(/_/g, " ") %>
                  </strong>
                </div>
              </div>

              <div class="consult-order-items">
                <h3>Produtos</h3>

                <% order.items.forEach((item) => { %>
                  <div class="consult-order-item">
                    <div>
                      <strong><%= item.name %></strong>
                      <span><%= item.quantity %>x <%= formatPrice(item.priceCents) %></span>
                    </div>

                    <strong><%= formatPrice(item.totalCents) %></strong>
                  </div>
                <% }) %>
              </div>

              <div class="consult-price-box">
                <div>
                  <span>Subtotal</span>
                  <strong><%= formatPrice(order.subtotal) %></strong>
                </div>

                <div>
                  <span>Cupom</span>
                  <strong><%= order.coupon || "Nenhum" %></strong>
                </div>

                <div>
                  <span>Desconto</span>
                  <strong>- <%= formatPrice(order.discount) %></strong>
                </div>

                <div class="consult-price-total">
                  <span>Total</span>
                  <strong><%= formatPrice(order.total) %></strong>
                </div>
              </div>

            <% } %>
          </div>

        </div>

      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>

</body>
</html>