<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <link rel="icon" type="image/png" href="/images/logo/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/pages/staff.css">
  <link rel="stylesheet" href="/css/pages/staff-store.css">
</head>
<body>

  <%- include("../partials/header") %>

  <main class="staff-store-page">
    <section class="staff-store-hero">
      <div class="container staff-store-hero-grid">
        <div>
          <span class="section-tag">Painel da Loja</span>
          <h1>Produtos da Loja</h1>
          <p>
            Edite preços, imagens, descrições e status dos itens da loja sem abrir código.
            Esta área é restrita aos Desenvolvedores do SurvivalZ.
          </p>

          <div class="staff-store-actions">
            <a href="/staff" class="staff-store-btn secondary">Voltar ao Staff</a>
            <a href="/staff/loja/produtos/novo" class="staff-store-btn primary">+ Novo produto</a>
          </div>
        </div>

        <div class="staff-store-stats">
          <article>
            <span>Total</span>
            <strong><%= stats.total %></strong>
          </article>
          <article>
            <span>Ativos</span>
            <strong><%= stats.active %></strong>
          </article>
          <article>
            <span>Destaques</span>
            <strong><%= stats.featured %></strong>
          </article>
          <article>
            <span>Inativos</span>
            <strong><%= stats.inactive %></strong>
          </article>
        </div>
      </div>
    </section>

    <section class="container staff-store-panel">
      <form class="staff-store-filter" method="GET" action="/staff/loja/produtos">
        <div class="staff-store-search">
          <span>🔎</span>
          <input type="search" name="q" value="<%= search %>" placeholder="Buscar produto, veículo, VIP, ID...">
        </div>

        <select name="category">
          <option value="all" <%= category === "all" ? "selected" : "" %>>Todas as categorias</option>
          <% categoryOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= category === option.value ? "selected" : "" %>>
              <%= option.label %>
            </option>
          <% }) %>
        </select>

        <button type="submit">Filtrar</button>
        <a href="/staff/loja/produtos">Limpar</a>
      </form>

      <% if (!products.length) { %>
        <div class="staff-store-empty">
          <strong>Nenhum produto encontrado</strong>
          <p>
            Use o botão “Novo produto” ou importe a base de preços para começar.
          </p>
          <a href="/staff/loja/produtos/novo" class="staff-store-btn primary">Criar produto</a>
        </div>
      <% } else { %>
        <div class="staff-store-grid">
          <% products.forEach((product) => { %>
            <article class="staff-store-product-card <%= !product.isActive ? 'is-inactive' : '' %>">
              <div class="staff-store-product-image">
                <img src="<%= product.imageUrl || '/images/products/default.png' %>" alt="<%= product.name %>">
                <span class="staff-store-status <%= product.isActive ? 'active' : 'inactive' %>">
                  <%= product.isActive ? 'Ativo' : 'Inativo' %>
                </span>
              </div>

              <div class="staff-store-product-body">
                <div class="staff-store-product-tags">
                  <span><%= product.categoryLabel %></span>
                  <% if (product.isFeatured) { %>
                    <strong>Destaque</strong>
                  <% } %>
                </div>

                <h2><%= product.name %></h2>

                <% if (product.description) { %>
                  <p><%= product.description %></p>
                <% } else { %>
                  <p class="muted">Sem descrição cadastrada.</p>
                <% } %>

                <div class="staff-store-price-row">
                  <div>
                    <span>Preço principal</span>
                    <strong><%= product.category === 'zcoins' ? product.referencePriceLabel : product.priceZCoinsLabel %></strong>
                  </div>
                  <div>
                    <span><%= product.category === 'zcoins' ? 'Entrega' : 'Referência' %></span>
                    <strong><%= product.category === 'zcoins' ? product.priceZCoinsLabel : product.referencePriceLabel %></strong>
                  </div>
                </div>

                <% if (product.modelId || product.capacityKg || product.armorTier || product.collection) { %>
                  <div class="staff-store-meta-list">
                    <% if (product.modelId) { %><span>ID <%= product.modelId %></span><% } %>
                    <% if (product.capacityKg) { %><span><%= product.capacityKg %>kg</span><% } %>
                    <% if (product.armorTier) { %><span><%= product.armorTier %></span><% } %>
                    <% if (product.collection) { %><span><%= product.collection %></span><% } %>
                  </div>
                <% } %>
              </div>

              <div class="staff-store-product-actions">
                <a href="/staff/loja/produtos/<%= product.id %>/editar">Editar</a>

                <form method="POST" action="/staff/loja/produtos/<%= product.id %>/toggle">
                  <button type="submit"><%= product.isActive ? 'Desativar' : 'Ativar' %></button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
